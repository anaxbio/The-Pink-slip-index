<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Pink Slip Index | Quick-Start Runway Baseline</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        :root { 
            --bg-main: #FAFAFA; 
            --bg-card: #FFFFFF; 
            --text-main: #0F172A; 
            --text-muted: #64748B; 
            --border-color: #E2E8F0; 
            --accent-safe: #10B981; 
            --accent-danger: #EF4444; 
            --accent-primary: #2563EB; 
        }
        body { background-color: var(--bg-main); color: var(--text-main); font-family: 'Inter', sans-serif; padding: 20px; margin: 0; min-height: 100vh; display: flex; flex-direction: column; -webkit-font-smoothing: antialiased; justify-content: center; }
        #app-container { display: flex; width: 95%; max-width: 1400px; margin: 0 auto; flex-direction: column; gap: 24px; }
        
        .simple-hero { text-align: center; margin-bottom: 5px; }
        .simple-hero h1 { font-size: 2.8rem; font-weight: 800; letter-spacing: -0.04em; margin: 0 0 10px 0; color: var(--text-main); }
        .simple-hero p { font-size: 1.1rem; color: var(--text-muted); max-width: 800px; margin: 0 auto; line-height: 1.5; font-weight: 500; }
        
        /* TWO BLOCK SIDE-BY-SIDE PLATFORM SPLIT SCREEN GRID */
        .workbench-split-deck { display: grid; grid-template-columns: 50fr 50fr; gap: 30px; align-items: stretch; margin-top: 10px; margin-bottom: 10px; }
        
        /* BLOCK 1: BASELINE INPUT SLIP */
        .simple-grid { background: var(--bg-card); padding: 35px; border-radius: 16px; border: 1px solid var(--border-color); box-shadow: 0 10px 25px -5px rgba(0,0,0,0.02); display: flex; flex-direction: column; gap: 20px; box-sizing: border-box; height: 100%; }
        .input-row-layout { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
        .simple-input-group label { display: block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); margin-bottom: 8px; }
        .simple-input-group input { width: 100%; padding: 14px; font-size: 1.35rem; font-family: 'JetBrains Mono', monospace; font-weight: 700; border: 2px solid var(--border-color); border-radius: 8px; background: #FAFAFA; color: var(--text-main); box-sizing: border-box; transition: 0.2s; }
        .simple-input-group input:focus { border-color: var(--accent-primary); outline: none; background: #FFFFFF; box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1); }
        .simple-input-group .helper-text { font-size: 0.75rem; color: var(--accent-primary); font-weight: 600; margin-top: 6px; display: block; }
        .input-sub-label { font-size: 0.75rem; color: var(--text-muted); font-weight: 500; display: block; margin-top: -6px; margin-bottom: 8px; text-transform: none; }
        
        /* BLOCK 2: LIGHT MODE DYNAMIC RECOVERY TERMINAL */
        .verdict-box { background: var(--bg-card); color: var(--text-main); padding: 35px; border-radius: 16px; display: flex; flex-direction: column; justify-content: space-between; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.02); border: 1px solid var(--border-color); box-sizing: border-box; height: 100%; }
        .verdict-box.danger { background: #FEF2F2; border: 1px solid #FCA5A5; }
        .verdict-header-block { text-align: center; border-bottom: 1px dashed var(--border-color); padding-bottom: 25px; margin-bottom: 20px; }
        .verdict-box.danger .verdict-header-block { border-bottom-color: #FCA5A5; }
        .verdict-label { font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 8px; }
        .verdict-value { font-size: 4.2rem; font-weight: 800; font-family: 'JetBrains Mono', monospace; letter-spacing: -0.04em; margin: 0; line-height: 1; color: var(--accent-safe); }
        .verdict-box.danger .verdict-value { color: var(--accent-danger); }
        
        /* ROADMAP FILING CHECKLIST GUIDE */
        .roadmap-guide-frame { display: flex; flex-direction: column; gap: 16px; flex-grow: 1; justify-content: center; }
        .roadmap-guide-title { font-size: 0.8rem; font-weight: 500; color: var(--text-muted); margin-bottom: 4px; line-height: 1.4; }
        .roadmap-step-row { display: flex; gap: 12px; align-items: flex-start; font-size: 0.85rem; line-height: 1.4; color: var(--text-main); }
        .roadmap-step-num { background: #F1F5F9; border: 1px solid var(--border-color); color: var(--text-main); font-family: 'JetBrains Mono'; font-weight: 700; font-size: 0.75rem; width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .verdict-box.danger .roadmap-step-num { background: #FEE2E2; border-color: #FCA5A5; color: #991B1B; }
        .roadmap-step-text strong { color: var(--text-main); display: block; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.02em; margin-bottom: 1px; }

        /* WING SYSTEM DECK LOWER PANELS */
        .wing-split-deck { display: grid; grid-template-columns: 50fr 50fr; gap: 30px; margin-top: 15px; margin-bottom: 15px; }
        .wing-card { background: var(--bg-card); border: 1px solid var(--border-color); padding: 24px; border-radius: 12px; font-size: 0.85rem; line-height: 1.6; color: var(--text-muted); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.01); box-sizing: border-box; }
        .wing-card h4 { margin: 0 0 8px 0; font-size: 0.9rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-main); }
        
        /* TRANSITION BUTTON TRIGGER RUNWAY FOOTER */
        .advanced-toggle-wrapper { margin-top: 5px; }
        .advanced-btn { background: var(--accent-primary); border: none; color: white; padding: 18px 32px; border-radius: 10px; font-size: 1.15rem; font-weight: 700; cursor: pointer; transition: all 0.2s ease; font-family: 'Inter', sans-serif; width: 100%; box-sizing: border-box; box-shadow: 0 4px 14px rgba(37, 99, 235, 0.25); text-transform: uppercase; letter-spacing: 0.02em; }
        .advanced-btn:hover { background: #1D4ED8; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(37, 99, 235, 0.35); }
    </style>
</head>
<body>
    <div id="app-container">
        <div class="simple-hero">
            <h1>The Pink Slip Index</h1>
            <p>Calculate exactly how many months your personal financial reserves can protect your family if your active paycheck drops to zero.</p>
        </div>
        
        <div class="workbench-split-deck">
            <div class="simple-grid" id="simple_inputs_container">
                <div class="input-row-layout">
                    <div class="simple-input-group">
                        <label>💸 Monthly Take-Home Salary (₹)</label>
                        <input type="number" id="simp_income" value="50000">
                        <span class="helper-text" id="simp_words_income">Fifty Thousand Rupees</span>
                    </div>
                    <div class="simple-input-group">
                        <label>🔥 Your Monthly Expenses (₹)</label>
                        <input type="number" id="simp_burn" value="35000">
                        <span class="helper-text" id="simp_words_burn">Thirty Five Thousand Rupees</span>
                    </div>
                </div>
                
                <div class="input-row-layout">
                    <div class="simple-input-group">
                        <label>💰 Your Liquid Assets (₹)</label>
                        <span class="input-sub-label">(FD, Demat, MFs, Cash, Gold)</span>
                        <input type="number" id="simp_assets" value="1500000">
                        <span class="helper-text" id="simp_words_assets">Fifteen Lakhs Rupees</span>
                    </div>
                    <div class="simple-input-group">
                        <label>🏡 Value of Your House (₹)</label>
                        <span class="input-sub-label">(Estimated Property Market Value)</span>
                        <input type="number" id="simp_house" value="4000000">
                        <span class="helper-text" id="simp_words_house">Forty Lakhs Rupees</span>
                    </div>
                </div>

                <div class="input-row-layout">
                    <div class="simple-input-group" style="grid-column: span 2; margin-bottom: 0;">
                        <label>⚠️ Total Property &amp; Home Loans (₹)</label>
                        <span class="input-sub-label">(Includes: Home, Car, Personal, Top-Up Debt)</span>
                        <input type="number" id="simp_debt" value="4000000">
                        <span class="helper-text" id="simp_words_debt">Forty Lakhs Rupees</span>
                    </div>
                </div>
                
                <div class="input-row-layout" style="border-top: 1px dashed var(--border-color); padding-top: 15px; margin-top: 5px;">
                    <div class="simple-input-group">
                        <label>⚡ Your Age</label>
                        <input type="number" id="simp_age" value="45">
                    </div>
                    <div class="simple-input-group">
                        <label>👨‍👩‍👧‍👦 Number of Dependents</label>
                        <input type="number" id="simp_dependents" value="2">
                    </div>
                </div>
            </div>

            <div id="verdict_banner" class="verdict-box safe">
                <div class="verdict-header-block">
                    <div class="verdict-label" id="verdict_status_text">Your Money Reserve</div>
                    <div class="verdict-value">
                        <span id="verdict_months">0</span> 
                        <span style="font-size: 2rem; color: var(--text-muted); font-family: 'Inter'; font-weight: 700; letter-spacing: 0;">Months</span>
                    </div>
                    <div style="font-size: 1.05rem; font-weight: 600; color: var(--text-muted); margin-top: 5px;" id="lbl_calculated_years">(0.0 Years of Fuel)</div>
                </div>
                
                <div class="roadmap-guide-frame">
                    <div class="roadmap-guide-title" id="lbl_diagnostic_prompt">This number is basic number. On the next page, we find out what breaks your money reserve in a proper way.</div>
                    
                    <div class="roadmap-step-row">
                        <div class="roadmap-step-num">1</div>
                        <div class="roadmap-step-text">
                            <strong>📉 The Expense Drilldown</strong>
                            check detailed monthly expenses. seperate your fixed home EMIs and family costs from your luxury spending.
                        </div>
                    </div>
                    
                    <div class="roadmap-step-row">
                        <div class="roadmap-step-num">2</div>
                        <div class="roadmap-step-text">
                            <strong>☣️ Real-World Market Shocks</strong>
                            See what a market crash does to your real liquid cash pool while your home value stays locked.
                        </div>
                    </div>
                    
                    <div class="roadmap-step-row">
                        <div class="roadmap-step-num">3</div>
                        <div class="roadmap-step-text">
                            <strong>🛑 The Termination Notice Card</strong>
                            Try Cutting down your salary to zero to check your true runway moeny resreve.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="wing-split-deck">
            <div class="wing-card">
                <h4>The reality</h4>
                Standard financial projections often keep you passive. They encourage looking at static, round-number baselines that hide lifestyle vulnerabilities. These fields are unverified estimates—the sandbox workbench is where we evaluate how your capital reserves actually sustain your dependents when primary active payroll handles shift or drop entirely.
            </div>
            <div class="wing-card">
                <h4>SEBI / ICAI Compliance</h4>
                This application is an abstract mathematical simulation model, not a regulated financial planning product or advisory service. In strict compliance with regulatory codes, the operator is a CA qualified to provide professional tax advice; however, this tool does not offer investment advice, customized asset allocation strategies, or product recommendations.
            </div>
        </div>

        <div class="advanced-toggle-wrapper">
            <button class="advanced-btn" id="btn_goto_advanced">
                🔥 START DETAILED ESTIMATE AND WORKBENCH →
            </button>
        </div>
    </div>

    <script>
        const storageKey = 'pinkslip_funnel_state';
        const fmt = (num) => new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 }).format(num || 0);

        function formatIndianWords(number) {
            if (!number || number === 0) return "Zero Rupees";
            const crores = Math.floor(number / 10000000); let remainder = number % 10000000;
            const lakhs = Math.floor(remainder / 100000); remainder = remainder % 100000;
            const thousands = Math.floor(remainder / 1000); const rupees = remainder % 1000;
            let result = [];
            if (crores > 0) result.push(`${crores} Crore${crores > 1 ? 's' : ''}`);
            if (lakhs > 0) result.push(`${lakhs} Lakh${lakhs > 1 ? 's' : ''}`);
            if (thousands > 0) result.push(`${thousands} Thousand`);
            if (rupees > 0 || result.length === 0) result.push(`${rupees} Rupee${rupees > 1 || rupees === 0 ? 's' : ''}`);
            return result.join(" ");
        }

        function saveState() {
            const state = {
                income: Number(document.getElementById('simp_income').value) || 0,
                burn: Number(document.getElementById('simp_burn').value) || 0,
                assets: Number(document.getElementById('simp_assets').value) || 0,
                house: Number(document.getElementById('simp_house').value) || 0,
                debt: Number(document.getElementById('simp_debt').value) || 0,
                age: Number(document.getElementById('simp_age').value) || 45,
                dependents: Number(document.getElementById('simp_dependents').value) || 0
            };
            localStorage.setItem(storageKey, JSON.stringify(state));
        }

        function loadState() {
            const saved = localStorage.getItem(storageKey);
            if (saved) {
                try {
                    const state = JSON.parse(saved);
                    if(state.income) document.getElementById('simp_income').value = state.income;
                    if(state.burn) document.getElementById('simp_burn').value = state.burn;
                    if(state.assets) document.getElementById('simp_assets').value = state.assets;
                    if(state.house) document.getElementById('simp_house').value = state.house;
                    if(state.debt) document.getElementById('simp_debt').value = state.debt;
                    if(state.age) document.getElementById('simp_age').value = state.age;
                    if(state.dependents) document.getElementById('simp_dependents').value = state.dependents;
                } catch(e) { console.error(e); }
            }
        }

        function updateWordDisplays() {
            ['simp_income', 'simp_burn', 'simp_assets', 'simp_house', 'simp_debt'].forEach(id => {
                const el = document.getElementById(id);
                const wordDiv = document.getElementById('simp_words_' + id.split('_')[1]);
                if (el && wordDiv) {
                    wordDiv.innerText = formatIndianWords(Number(el.value));
                }
            });
        }

        function calculateVerdict() {
            saveState();
            const inflow = Number(document.getElementById('simp_income').value) || 0;
            const burn = Number(document.getElementById('simp_burn').value) || 0;
            const assets = Number(document.getElementById('simp_assets').value) || 0;
            const debt = Number(document.getElementById('simp_debt').value) || 0;
            const age = Number(document.getElementById('simp_age').value) || 45;

            let liquid_pool = Math.max(0, assets - debt); 
            let completed_months = 0; 
            let current_burn = burn;
            const inflation_pct = 0.06;

            for (let m = 1; m <= 600; m++) {
                let real_inflow = (age + (m/12)) >= 60 ? 0 : inflow; 
                let monthly_deficit = current_burn - real_inflow;
                if (monthly_deficit > 0) { 
                    liquid_pool -= monthly_deficit; 
                    if (liquid_pool <= 0) break; 
                } else { 
                    liquid_pool += Math.abs(monthly_deficit); 
                }
                liquid_pool *= (1 + (0.07 / 12)); 
                completed_months++;
                if (m % 12 === 0) current_burn *= (1 + inflation_pct);
            }

            const banner = document.getElementById('verdict_banner'); 
            const calculatedYears = (completed_months / 12).toFixed(1);
            
            document.getElementById('verdict_months').innerText = fmt(completed_months);
            document.getElementById('lbl_calculated_years').innerText = `(${calculatedYears} Years of Fuel)`;
            
            if (completed_months < 12) { 
                banner.className = "verdict-box danger"; 
                document.getElementById('verdict_status_text').innerText = "Your Money Reserve"; 
                document.getElementById('lbl_diagnostic_prompt').innerText = "Your money reserve breaches almost immediately. On the next page, run the metrics to analyze the damage:";
            } else { 
                banner.className = "verdict-box safe"; 
                document.getElementById('verdict_status_text').innerText = "Your Money Reserve"; 
                document.getElementById('lbl_diagnostic_prompt').innerText = "This number is basic number. On the next page, we find out what breaks your money reserve in a proper way.";
            }
        }

        const inputs = ['simp_income', 'simp_burn', 'simp_assets', 'simp_house', 'simp_debt', 'simp_age', 'simp_dependents'];
        inputs.forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.addEventListener('input', () => {
                    if (id !== 'simp_age' && id !== 'simp_dependents') {
                        const wordDiv = document.getElementById('simp_words_' + id.split('_')[1]);
                        if(wordDiv) wordDiv.innerText = formatIndianWords(Number(el.value));
                    }
                    calculateVerdict();
                });
            }
        });

        document.getElementById('btn_goto_advanced').addEventListener('click', () => {
            saveState();
            window.location.href = 'workbench.html';
        });

        loadState();
        updateWordDisplays();
        calculateVerdict();
    </script>
</body>
</html>
