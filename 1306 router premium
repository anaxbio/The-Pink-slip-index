# --- PRODUCTION CALCULATION LOOP ENGINE ---
@router.post("/v2/vault_calc")
async def process_flat_premium_math(data: VaultFlatPayload, token_payload: dict = Depends(verify_premium_token)):
    """
    Executes deep multi-asset volatility projections entirely within isolated server RAM.
    Unblends commodities from fixed properties, patches early termination bugs, and binds slider yields.
    """
    is_panic = data.panic_toggle
    active_inflow = 0.0 if is_panic else data.total_active_inflows
    total_inflow = active_inflow + data.total_passive_inflows

    # SIMPLIFIED THE BASELINE MONTHLY TOTAL RUNNING VALUE USING THE AGREED VARIABLES
    raw_monthly_burn = data.total_fixed_bank_emis + data.total_inflating_lifestyle_costs

    # UNPACKED THE CONSOLIDATED SYSTEM SPIKES
    raw_annual_spikes = data.total_annual_spikes

    # Unpacking System Macro Allocation Structures
    equity_base = data.total_equity_base
    debt_base = data.total_debt_base
    cash_base = data.total_cash_base
    metals_base = data.total_metals_base
    real_estate_base = data.total_real_estate_base

    home_loan_base = data.total_mortgage_debts
    other_loan_base = data.total_other_debts
    total_debts = home_loan_base + other_loan_base

    absolute_expense_shock = raw_monthly_burn * (data.expense_shock / 100)
    base_monthly_outflow = raw_monthly_burn + absolute_expense_shock + (raw_annual_spikes / 12)

    final_equity = equity_base * (1 + (data.equity_shift / 100))
    final_metals = metals_base * (1 + (data.metals_shift / 100))

    # Calculate day-zero liquidation friction penalties
    if is_panic:
        total_eq_loss = data.stcg_equity * 0.20
        other_loss = debt_base * 0.01
        if data.re_liquidation > 0 and real_estate_base > 0:
            re_loss = (data.re_liquidation * (data.re_distress_pct / 100)) + (data.re_taxable_gain * (data.re_liquidation / real_estate_base) * 0.125)
        else:
            re_loss = 0.0
    else:
        total_eq_loss = max(0.0, final_equity - (equity_base * 0.7)) * 0.125
        re_loss = max(0.0, data.re_liquidation - (data.re_liquidation * 0.6)) * 0.125 if data.re_liquidation > 0 else 0.0
        other_loss = debt_base * 0.05

    total_friction = total_eq_loss + re_loss + other_loss
    effective_re_released = max(0.0, data.re_liquidation - re_loss - home_loan_base)

    # Initialize simulation timelines (Unblending commodities completely)
    sim_eq = final_equity - total_eq_loss
    sim_db = (debt_base - other_loss) + cash_base + effective_re_released
    sim_hd_re = real_estate_base - data.re_liquidation
    sim_hd_met = final_metals

    completed_months = 0
    timeline_burn_rate = base_monthly_outflow
    
    active_simulated_rent = int(round((real_estate_base * 0.03) / 12)) if data.re_liquidation > 0 else 0
    loop_simulated_rent = data.simulated_monthly_rent if data.simulated_monthly_rent > 0 else active_simulated_rent
    current_rental_yield = data.total_passive_inflows

    # Assign dynamic cockpit returns and tax drags
    eq_growth_fraction = data.expected_equity_yield / 100
    fi_growth_fraction = data.expected_fixed_yield / 100
    met_growth_fraction = data.expected_commodity_yield / 100
    tax_drag_fraction = data.portfolio_tax_drag / 100

    # Month-by-month capital simulation matrix (Max 50 years)
    for m in range(1, 601):
        sim_age = data.current_age + (m / 12)
        
        # Compound individual asset classes independently
        sim_eq *= (1 + (eq_growth_fraction / 12) - (tax_drag_fraction / 12))
        sim_db *= (1 + (fi_growth_fraction / 12) - (tax_drag_fraction / 12))
        sim_hd_re *= (1 + (0.05 / 12)) 
        sim_hd_met *= (1 + (met_growth_fraction / 12) - (tax_drag_fraction / 12))

        # Enforce mathematical boundaries (Stop sub-zero compounding errors)
        sim_eq = max(0.0, sim_eq)
        sim_db = max(0.0, sim_db)
        sim_hd_re = max(0.0, sim_hd_re)
        sim_hd_met = max(0.0, sim_hd_met)

        active_career_inflow = 0.0 if sim_age >= 60 else active_inflow
        if m % 12 == 0:
            current_rental_yield *= 0.98
        real_time_inflow = active_career_inflow + (0.0 if is_panic else current_rental_yield)

        # REPLACED OLD COMPLEX EQUATION WITH AGREED SUBTRACTION RULE TO SHIELD CONTRACT EMIs FROM INFLATION
        running_monthly_burn = (timeline_burn_rate - data.total_fixed_bank_emis) + loop_simulated_rent
        monthly_deficit = running_monthly_burn - real_time_inflow

        if monthly_deficit > 0:
            # Cascading Attrition Rule 1: Drain Liquid Cash & Debt
            if sim_db >= monthly_deficit:
                sim_db -= monthly_deficit
            else:
                short = monthly_deficit - sim_db
                sim_db = 0
                
                # Cascading Attrition Rule 2: Liquify Equities
                if sim_eq >= short:
                    sim_eq -= short
                else:
                    short = short - sim_eq
                    sim_eq = 0
                    
                    # Cascading Attrition Rule 3: Liquidate Precious Metals / Commodities
                    if sim_hd_met >= short:
                        sim_hd_met -= short
                    else:
                        short = short - sim_hd_met
                        sim_hd_met = 0
                        
                        # Cascading Attrition Rule 4: Deplete Fixed Property Values
                        if sim_hd_re >= short:
                            sim_hd_re -= short
                        else:
                            sim_hd_re = 0
                            break # Core bankruptcy reached
        else:
            sim_db += abs(monthly_deficit)

        completed_months += 1
        if m % 12 == 0:
            timeline_burn_rate *= (1 + (data.inflation_slider / 100))
            loop_simulated_rent *= (1 + (data.inflation_slider / 100))

    surviving_pool = sim_eq + sim_db + sim_hd_re + sim_hd_met

    return {
        "completed_months": completed_months,
        "total_friction": total_friction,
        "total_eq_loss": total_eq_loss,
        "re_loss": re_loss,
        "other_loss": other_loss,
        "effective_re_released": effective_re_released,
        "final_equity": final_equity,
        "final_metals": final_metals,
        "equity_base": equity_base,
        "debt_base": debt_base,
        "cash_base": cash_base,
        "metals_base": metals_base,
        "real_estate_base": real_estate_base,
        "home_loan_base": home_loan_base,
        "total_debts": total_debts,
        "raw_monthly_burn": raw_monthly_burn,
        "raw_annual_spikes": raw_annual_spikes,
        "surviving_pool": surviving_pool
    }


# --- HEAVY AUTH GATED LIFECYCLE (EXECUTED ONCE PER SESSION INTERACTION) ---
@router.post("/api/v2/auth/login")
async def verify_google_identity_session(payload: GoogleAuthPayload):
    """
    Validates Google identity tokens, references private local storage whitelist ledger documents,
    and dispenses rapid, locally verifiable RAM app authorization tokens.
    """
    try:
        # Validate directly against Google's public signature confirmation channel
        verify_url = f"https://oauth2.googleapis.com/tokeninfo?id_token={payload.id_token}"
        res = requests.get(verify_url, timeout=10)
        
        if not res.ok:
            raise HTTPException(status_code=401, detail="Google authentication validation handshake failure.")
            
        g_data = res.json()
        
        # Security Guard: Confirm token target is matching our system client ID explicitly
        if g_data.get("aud") != GOOGLE_CLIENT_ID:
            raise HTTPException(status_code=403, detail="Audience configuration mismatch tracking parameters.")
            
        user_email = g_data.get("email", "").lower().strip()
        if not user_email:
            raise HTTPException(status_code=401, detail="Unable to retrieve verified email string from identity token.")
            
        # Hard Barrier Check: Scan private file whitelist ledger document sitting in server root
        if not os.path.exists(WHITELIST_FILE_PATH):
            raise HTTPException(status_code=500, detail="Internal authorization tracking components absent.")
            
        is_allowed_member = False
        with open(WHITELIST_FILE_PATH, "r") as f:
            whitelisted_emails = [line.strip().lower() for line in f.readlines() if line.strip()]
            if user_email in whitelisted_emails:
                is_allowed_member = True
                
        if not is_allowed_member:
            raise HTTPException(status_code=403, detail="Your authenticated identity profile is absent from our premium whitelist system ledger.")
            
        # Initialization Passed: Dispatch fast local token signed in memory valid for 7 days
        session_claims = {
            "sub": user_email,
            "exp": int(time.time()) + (7 * 24 * 60 * 60)
        }
        local_app_token = jwt.encode(session_claims, JWT_SECRET, algorithm=JWT_ALGORITHM)
        
        return {"pinkslip_token": local_app_token, "email": user_email}
        
    except HTTPException as he:
        raise he
    except requests.RequestException as re:
        raise HTTPException(status_code=503, detail=f"External identity server verification timeout/error: {str(re)}")
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Google identity login fatal internal exception: {type(e).__name__} - {str(e)}")


