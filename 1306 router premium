# --- PLUG-AND-PLAY WEBHOOK CHANNEL (BLIND PIPELINE ACCESS LOCK) ---
@router.post("/api/v2/payment-callback")
async def execute_isolated_ledger_update(request: Request):
    """
    Headless webhook collector parsing validated payment engine packets.
    Extracts the authenticated email address, appends tracking arrays to the whitelist file, and kills connection.
    """
    try:
        raw_body = await request.json()
        customer_email = None
        
        if "payload" in raw_body and "payment" in raw_body["payload"]:
            customer_email = raw_body["payload"]["payment"]["entity"].get("email", "").lower().strip()
        elif "email" in raw_body:
            customer_email = raw_body.get("email", "").lower().strip()
            
        if not customer_email or "@" not in customer_email:
            raise HTTPException(status_code=400, detail="Unable to extract verified transactional target metadata.")
            
        # --- FIXED TWO-STEP TEXT FILE WRITING BLOCK ---
        existing_records = []
        needs_newline = False
        
        # Step 1: Read current states safely using standalone execution streams
        if os.path.exists(WHITELIST_FILE_PATH):
            with open(WHITELIST_FILE_PATH, "r") as f:
                lines = f.readlines()
                existing_records = [line.strip().lower() for line in lines if line.strip()]
                if lines and not lines[-1].endswith("\n"):
                    needs_newline = True

        # Step 2: Append data without internal pointer drift errors
        if customer_email not in existing_records:
            with open(WHITELIST_FILE_PATH, "a") as f:
                if needs_newline:
                    f.write(f"\n{customer_email}\n")
                else:
                    f.write(f"{customer_email}\n")
                
        return {"status": "synchronized", "ledger": "updated"}
    except HTTPException as he:
        raise he
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Webhook operational processing failed: {type(e).__name__} - {str(e)}")
