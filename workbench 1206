        function formatIndianWords(number) {
            if (!number || number === 0) return "Zero Rupees";
            const crores = Math.floor(number / 10000000); let remainder = number % 10000000;
            const lakhs = Math.floor(remainder / 100000); remainder = remainder % 100000;
            const thousands = Math.floor(remainder / 1000); const rupees = remainder % 1000;
            let result = [];
            if (crores > 0) result.push(`${crores} Crore${crores > 1 ? 's' : ''}`);
            if (lakhs > 0) result.push(`${lakhs} Lakh${lakhs > 1 ? 's' : ''}`);
            if (thousands > 0) result.push(`${thousands} Thousand`);
            if (rupees > 0 || result.length === 0) result.push(`${rupees} Rupee${rupees > 1 || rupees === 0 ? 's' : ''}`);
            return result.join(" ");
        }

        /* ACTIONS WALKTHROUGH CONTROLLER WITH AUTOSCROLL */
        function triggerStepFocus(stepNumber) {
            document.querySelectorAll('.flow-step-item').forEach(el => el.classList.remove('active-step'));
            document.getElementById('hand_pointer_1').style.display = 'none';
            document.getElementById('hand_pointer_2').style.display = 'none';
            document.getElementById('hand_pointer_3').style.display = 'none';

            const sidebar = document.getElementById('onboard_sidebar_block');
            const scenarios = document.getElementById('onboard_scenarios_block');
            const thermometer = document.getElementById('thermometer_block');
            const proDeck = document.getElementById('onboard_pro_deck_block');

            // Strip current highlight layers
            sidebar.classList.remove('highlighted-focus-ring');
            scenarios.classList.remove('highlighted-focus-ring');
            thermometer.classList.remove('highlighted-focus-ring');
            proDeck.classList.remove('highlighted-focus-ring-danger');

            if (stepNumber === 1) {
                activeGuidedStep = 1;
                document.getElementById('step_trigger_1').classList.add('active-step');
                document.getElementById('hand_pointer_1').style.display = 'block';
                sidebar.classList.add('highlighted-focus-ring');
            } 
            else if (stepNumber === 2) {
                activeGuidedStep = 2;
                document.getElementById('step_trigger_2').classList.add('active-step');
                document.getElementById('hand_pointer_2').style.display = 'block';
                scenarios.classList.add('highlighted-focus-ring');
                thermometer.classList.add('highlighted-focus-ring');
            } 
            else if (stepNumber === 3) {
                activeGuidedStep = 3;
                document.getElementById('step_trigger_3').classList.add('active-step');
                document.getElementById('hand_pointer_3').style.display = 'block';
                proDeck.classList.add('highlighted-focus-ring-danger');
                
                // AUTO-SCROLL DOWN FIX TO PULL HIDDEN PREMIUM BLOCK INTO USER LINE OF SIGHT
                proDeck.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

