            const btn = document.getElementById(btnId);
            if (btn) {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('.drawer').forEach(d => d.classList.remove('active'));
                    document.querySelectorAll('.drawer-btn').forEach(b => b.classList.remove('active'));
                    document.getElementById(drawerId).classList.add('active');
                    e.target.classList.add('active');
                });
            }
        };
        bindDrawer('nav-costs', 'drawer-costs'); bindDrawer('nav-income', 'drawer-income'); bindDrawer('nav-money', 'drawer-money'); bindDrawer('nav-loans', 'drawer-loans');
        
        function toggleAccordion(el) {
            const content = el.nextElementSibling;
            const icon = el.querySelector('span');
            if (content.classList.contains('active')) { content.classList.remove('active'); icon.innerText = '▼'; }
            else { content.classList.add('active'); icon.innerText = '▲'; }
        }
        
        document.getElementById('btn-reset-sliders').addEventListener('click', () => {
            document.getElementById('equity_shift').value = 0; 
            document.getElementById('metals_shift').value = 0; 
            document.getElementById('expense_shock').value = 0; 
            document.getElementById('inflation_slider').value = 6;
            document.querySelectorAll('#free-presets-strip .preset-pill-btn').forEach(b => b.classList.remove('active'));
            calculate();
        });
        
        function openPremiumModal() { document.getElementById('premium_modal').style.display = 'flex'; }
        function closePremiumModal() { document.getElementById('premium_modal').style.display = 'none'; document.getElementById('checkout_status').style.display = 'none'; document.getElementById('checkout_email').value = ''; }
        
        document.getElementById('btn_dummy_checkout').addEventListener('click', async () => {
            const emailInput = document.getElementById('checkout_email').value.trim();
            const statusDiv = document.getElementById('checkout_status');
            const btn = document.getElementById('btn_dummy_checkout');

            if (!emailInput || !emailInput.includes('@')) {
                statusDiv.style.display = 'block';
                statusDiv.style.background = '#450a0a';
                statusDiv.style.border = '1px solid #7f1d1d';
                statusDiv.style.color = '#fca5a5';
                statusDiv.innerText = "Please enter a valid email address.";
                return;
            }

            // Lock UI during transmit
            btn.innerText = "Initializing Gateway...";
            btn.style.opacity = "0.7";
            btn.style.pointerEvents = "none";
            statusDiv.style.display = 'none';

            try {
                // 1. Fetch backend callback configuration triggers
                const keyRes = await fetch('https://api.pinkslipindex.com/checkout/key');
                if (!keyRes.ok) throw new Error("Failed to retrieve gateway key.");
                const { key_id } = await keyRes.json();

                // 2. Request unique checkout session metrics
                const orderRes = await fetch('https://api.pinkslipindex.com/checkout/create_order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ customer_email: emailInput })
                });
                
                if (!orderRes.ok) throw new Error("Backend connection failed.");
                const { order_id } = await orderRes.json();

                // 3. Configure Razorpay sandbox dynamically
                const options = {
                    "key": key_id, 
                    "amount": 99900,
                    "currency": "INR",
                    "name": "Pink Slip Index",
                    "order_id": order_id, 
                    "handler": function (response) {
                        statusDiv.style.display = 'block';
                        statusDiv.style.background = '#064e3b';
                        statusDiv.style.border = '1px solid #047857';
                        statusDiv.style.color = '#6ee7b7';
                        statusDiv.innerText = "Payment Successful! Your access email has been whitelisted on the ledger document. Launch the Premium Vault workspace and authenticate using your Google Profile to unlock the deck.";
                        btn.innerText = "Identity Whitelisted";
                    },
                    "prefill": { "email": emailInput },
                    "theme": { "color": "#2563EB" }
                };

                const rzp = new Razorpay(options);
                rzp.open();
                
                rzp.on('payment.failed', function (response){
                    btn.innerText = "Secure Checkout via Razorpay";
                    btn.style.opacity = "1";
                    btn.style.pointerEvents = "auto";
                    alert("Payment failed. Please try again.");
                });

            } catch (err) {
                console.error(err);
                statusDiv.style.display = 'block';
                statusDiv.style.background = '#450a0a';
                statusDiv.style.border = '1px solid #7f1d1d';
                statusDiv.style.color = '#fca5a5';
                statusDiv.innerText = "Transaction initialization failed. Check your connection.";
                btn.innerText = "Secure Checkout via Razorpay";
                btn.style.opacity = "1";
                btn.style.pointerEvents = "auto";
            }
        });

        function openDamageReportModal() { document.getElementById('damage_modal').style.display = 'flex'; }
        function closeDamageReportModal() { document.getElementById('damage_modal').style.display = 'none'; }
        function transitionDamageToCheckout() { closeDamageReportModal(); openPremiumModal(); }

        function applyHistoricalScenario(scenarioType, btnRef) {
            document.querySelectorAll('#free-presets-strip .preset-pill-btn').forEach(b => b.classList.remove('active'));
            if (btnRef) btnRef.classList.add('active');
            
            const eqSlider = document.getElementById('equity_shift');
            const mtSlider = document.getElementById('metals_shift');
            const exSlider = document.getElementById('expense_shock');
            const infHidden = document.getElementById('inflation_slider');
            
            if (scenarioType === 'mehta') {
                eqSlider.value = -55; mtSlider.value = 0; exSlider.value = 0; infHidden.value = 10;
            } else if (scenarioType === 'lehman') {
                eqSlider.value = -50; mtSlider.value = 45; exSlider.value = 0; infHidden.value = 6;
            } else if (scenarioType === 'covid') {
                eqSlider.value = -35; mtSlider.value = -5; exSlider.value = 15; infHidden.value = 6;
            } else if (scenarioType === 'iran') {
                eqSlider.value = -15; mtSlider.value = 25; exSlider.value = 25; infHidden.value = 8;
            }
            calculate();

            if (activeGuidedStep === 2) {
                setTimeout(() => { triggerStepFocus(3); }, 1200);
            }
        }

        function updateAllWordDisplays() {
            const inputsToWordify = [
                'current_age', 'exp_rent_emi', 'exp_other_emi', 'exp_food_kirana', 'exp_utilities', 
                'exp_domestic_help', 'exp_fuel_commute', 'exp_dining_out', 'exp_misc_buffer',
                'inc_salary', 'ast_demat', 'ast_fd', 'ast_cash', 'ast_re', 'lia_home', 'lia_other'
            ];
            inputsToWordify.forEach(id => {
                const el = document.getElementById(id);
                const wordLabel = document.getElementById('lbl_word_' + id);
                if (el && wordLabel) {
                    wordLabel.innerText = formatIndianWords(Number(el.value));
                }
            });
        }

        function calculate() {
            updateAllWordDisplays();
            const age = Number(document.getElementById('current_age').value) || 45;
            
            const total_monthly_burn = (Number(document.getElementById('exp_rent_emi').value) || 0) + 
                                       (Number(document.getElementById('exp_other_emi').value) || 0) + 
                                       (Number(document.getElementById('exp_food_kirana').value) || 0) + 
                                       (Number(document.getElementById('exp_utilities').value) || 0) + 
                                       (Number(document.getElementById('exp_domestic_help').value) || 0) + 
                                       (Number(document.getElementById('exp_fuel_commute').value) || 0) + 
                                       (Number(document.getElementById('exp_dining_out').value) || 0) + 
                                       (Number(document.getElementById('exp_misc_buffer').value) || 0);
            
            document.getElementById('lbl_total_monthly_burn').innerText = fmt(total_monthly_burn);
            
            const equity_base = Number(document.getElementById('ast_demat').value) || 0;
            const debt_base = Number(document.getElementById('ast_fd').value) || 0;
            const cash_base = Number(document.getElementById('ast_cash').value) || 0;
            const re_base = Number(document.getElementById('ast_re').value) || 0;
            const total_assets = equity_base + debt_base + cash_base + re_base;
            document.getElementById('lbl_total_assets').innerText = fmt(total_assets);
            
            const liability_base = (Number(document.getElementById('lia_home').value) || 0) + 
                                   (Number(document.getElementById('lia_other').value) || 0);
            
            const equity_shift = Number(document.getElementById('equity_shift').value) || 0;
            const fixed_shift = Number(document.getElementById('metals_shift').value) || 0;
            const expense_shock_pct = Number(document.getElementById('expense_shock').value) || 0;
            const inflation_pct_val = Number(document.getElementById('inflation_slider').value) || 6;
            
            document.getElementById('lbl_eq_shift_badge').innerText = equity_shift + "%";
            document.getElementById('fill_eq_shift').style.width = ((equity_shift + 70) / 120 * 100) + "%";
            document.getElementById('thumb_eq_shift').style.left = ((equity_shift + 70) / 120 * 100) + "%";
            
            document.getElementById('lbl_met_shift_badge').innerText = fixed_shift + "%";
            document.getElementById('fill_met_shift').style.width = ((fixed_shift + 50) / 100 * 100) + "%";
            document.getElementById('thumb_met_shift').style.left = ((fixed_shift + 50) / 100 * 100) + "%";

            document.getElementById('lbl_exp_shock_badge').innerText = expense_shock_pct + "%";
            document.getElementById('fill_exp_shock').style.width = expense_shock_pct + "%";
            document.getElementById('thumb_exp_shock').style.left = expense_shock_pct + "%";

            document.getElementById('lbl_inflation_badge_val').innerText = inflation_pct_val + "%";
            document.getElementById('fill_inflation').style.width = (inflation_pct_val * 10) + "%";
            document.getElementById('thumb_inflation').style.left = (inflation_pct_val * 10) + "%";
            
            const inflow = Number(document.getElementById('inc_salary').value) || 0;
            const runtime_burn_adjusted = total_monthly_burn * (1 + (expense_shock_pct / 100));
            const net_cashflow = inflow - runtime_burn_adjusted;
            
            const cashflowBox = document.getElementById('cashflow_box');
            const cashflowLabel = document.getElementById('cashflow_label');
            const cashflowVal = document.getElementById('lbl_net_cashflow');
            
            if (net_cashflow >= 0) { 
                cashflowBox.className = "sidebar-cashflow-badge"; cashflowLabel.innerText = "CASH FLOW SURPLUS"; cashflowVal.innerText = "+₹" + fmt(net_cashflow); 
            } else { 
                cashflowBox.className = "sidebar-cashflow-badge deficit-flash"; cashflowLabel.innerText = "CASH FLOW DEFICIT"; cashflowVal.innerText = "-₹" + fmt(Math.abs(net_cashflow)); 
            }
            
            const shifted_equity = equity_base * (1 + (equity_shift / 100));
            const shifted_debt = debt_base * (1 + (fixed_shift / 100));
            
            let survival_liquid_estate = shifted_equity + shifted_debt + cash_base;
            let liquid_pool = Math.max(0, survival_liquid_estate - liability_base);
            let total_starting_liquid_pool = liquid_pool;
            let completed_months = 0;
            let current_loop_burn = runtime_burn_adjusted;
            const inflation_pct = inflation_pct_val / 100;
            
            for (let m = 1; m <= 600; m++) {
                let real_inflow = (age + (m/12)) >= 60 ? 0 : inflow;
                let monthly_deficit = current_loop_burn - real_inflow;
                if (monthly_deficit > 0) { liquid_pool -= monthly_deficit; if (liquid_pool <= 0) break; }
                else { liquid_pool += Math.abs(monthly_deficit); }
                liquid_pool *= (1 + (0.07 / 12));
                completed_months++;
                if (m % 12 === 0) current_loop_burn *= (1 + inflation_pct);
            }
            
            const terminalAgeTarget = 85;
            let yearsNeededToCover = Math.max(1, terminalAgeTarget - age);
            let calculatedYearsRunway = completed_months / 12;
            
            let rawPsiScore = 0;
            if (total_starting_liquid_pool > 0) {
                rawPsiScore = (calculatedYearsRunway / yearsNeededToCover) * 100;
            }
            let finalPsiScore = Math.min(100, Math.max(0, rawPsiScore));
            
            document.getElementById('val_months').innerText = fmt(completed_months) + " Months";
            document.getElementById('val_years').innerText = `(${calculatedYearsRunway.toFixed(1)} Yrs Runway Capacity)`;
            
            const progressFill = document.getElementById('bar_psi_fill');
            progressFill.style.width = finalPsiScore + '%';

            let targetFICorpus = runtime_burn_adjusted * 12 * 30; 
            let remainingDistanceGap = targetFICorpus - total_starting_liquid_pool;
            
            document.getElementById('lbl_nav_route').innerText = '₹' + fmt(targetFICorpus);
            
            const remainLabel = document.getElementById('lbl_nav_remain');
            if (remainingDistanceGap > 0) {
                remainLabel.innerText = '-₹' + fmt(remainingDistanceGap);
                remainLabel.style.color = '#EF4444';
            } else {
                remainLabel.innerText = 'ARRIVED';
                remainLabel.style.color = '#10B981';
            }

            const thermometerBlock = document.getElementById('thermometer_block');
            const scoreReadoutLabel = document.getElementById('lbl_green_score');
            
            if (scoreReadoutLabel) scoreReadoutLabel.innerText = finalPsiScore.toFixed(1);

            const targetRotationDegrees = -120 + (finalPsiScore * 2.4);
            const needleSvgObject = document.getElementById('gauge_needle_pin');
            if (needleSvgObject) needleSvgObject.style.transform = `rotate(${targetRotationDegrees}deg)`;

            const totalArcStrokeLength = 502; 
            const currentFillStrokeLength = (finalPsiScore / 100) * totalArcStrokeLength;
            const greenPathSegment = document.getElementById('gauge_green_fill');

            if (greenPathSegment) {
                greenPathSegment.style.display = 'block';
                greenPathSegment.style.strokeDasharray = `${currentFillStrokeLength} ${totalArcStrokeLength}`;
            }
            
            if (previousScore !== null && previousScore !== finalPsiScore) {
                thermometerBlock.classList.remove('shake-shock', 'celebrate-glow');
                void thermometerBlock.offsetWidth; 
                
                if (finalPsiScore < previousScore) {
                    thermometerBlock.classList.add('shake-shock');
                } else if (finalPsiScore >= 100.0 && previousScore < 100.0) {
                    thermometerBlock.classList.add('celebrate-glow');
                }
            }
            previousScore = finalPsiScore;
            
            const baselineDenominator = total_assets || 1;
            const survivalDenominator = survival_liquid_estate || 1;
            
            const baseEquityPct = Math.round((equity_base / baselineDenominator) * 100);
            const baseDebtPct = Math.round((debt_base / baselineDenominator) * 100);
            const baseCashPct = Math.round((cash_base / baselineDenominator) * 100);
            const baseRePct = Math.round((re_base / baselineDenominator) * 100);

            const survEquityPct = Math.round((shifted_equity / survivalDenominator) * 100);
            const survDebtPct = Math.round((shifted_debt / survivalDenominator) * 100);
            const survCashPct = Math.round((cash_base / survivalDenominator) * 100);
            const survRePct = Math.round((re_base / survivalDenominator) * 100);
            
            document.getElementById('vault_table').innerHTML = `
                <tr><td>Equity - MF+Direct</td><td>₹${fmt(equity_base)} (${baseEquityPct}%)</td><td><span style="color:${shifted_equity - equity_base >= 0 ? '#10B981' : '#EF4444'}">${equity_shift}%</span></td><td>₹${fmt(shifted_equity)} (${survEquityPct}%)</td></tr>
                <tr><td>FD+Debt MF</td><td>₹${fmt(debt_base)} (${baseDebtPct}%)</td><td><span style="color:${shifted_debt - debt_base >= 0 ? '#10B981' : '#EF4444'}">${fixed_shift}%</span></td><td>₹${fmt(shifted_debt)} (${survDebtPct}%)</td></tr>
                <tr><td>Savings / Cash Balance</td><td>₹${fmt(cash_base)} (${baseCashPct}%)</td><td><span>0%</span></td><td>₹${fmt(cash_base)} (${survCashPct}%)</td></tr>
                <tr><td>Real Estate</td><td>₹${fmt(re_base)} (${baseRePct}%)</td><td><span style="color:var(--text-muted)">[🔒 Locked]</span></td><td>₹${fmt(re_base)} (${survRePct}%)</td></tr>
            `;

            document.getElementById('dmg_base_eq').innerText = `${baseEquityPct}%`;
            document.getElementById('dmg_base_fd').innerText = `${baseDebtPct}%`;
            document.getElementById('dmg_base_cs').innerText = `${baseCashPct}%`;
            
            document.getElementById('dmg_surv_eq').innerText = `₹${fmt(shifted_equity)}`;
            document.getElementById('dmg_surv_fd').innerText = `₹${fmt(shifted_debt)}`;
            document.getElementById('dmg_surv_cs').innerText = `₹${fmt(cash_base)}`;
            
            document.getElementById('dmg_liquid_pool').innerText = `₹${fmt(total_starting_liquid_pool)}`;
            document.getElementById('dmg_fire_milestone').innerText = `₹${fmt(targetFICorpus)}`;
            
            const dmgShortfallEl = document.getElementById('dmg_shortfall_gap');
            if (remainingDistanceGap > 0) {
                dmgShortfallEl.innerText = `₹${fmt(remainingDistanceGap)}`;
                dmgShortfallEl.style.color = '#FF003C';
            } else {
                dmgShortfallEl.innerText = '0 (TARGET MILESTONE ACHIEVED)';
                dmgShortfallEl.style.color = '#10B981';
            }

            const denominator = total_assets || 1;
            const eq_weight = equity_base / denominator;
            const fd_weight = debt_base / denominator;
            const cash_weight = cash_base / denominator;
            const re_weight = re_base / denominator;

            const eq_3 = 14.5, eq_5 = 12.8, eq_10 = 11.5;
            const fd_3 = 7.1,  fd_5 = 6.8,  fd_10 = 7.0;
            const cs_3 = 3.5,  cs_5 = 3.5,  cs_10 = 3.5;
            const re_3 = 6.0,  re_5 = 5.5,  re_10 = 5.8;

            const blended_3 = (eq_weight * eq_3) + (fd_weight * fd_3) + (cash_weight * cs_3) + (re_weight * re_3);
            const blended_5 = (eq_weight * eq_5) + (fd_weight * fd_5) + (cash_weight * cs_5) + (re_weight * re_3);
            const blended_10 = (eq_weight * eq_10) + (fd_weight * fd_10) + (cash_weight * cs_10) + (re_weight * re_3);

            document.getElementById('v_3yr').innerText = "+" + blended_3.toFixed(1) + "% CAGR";
            document.getElementById('v_5yr').innerText = "+" + blended_5.toFixed(1) + "% CAGR";
            document.getElementById('v_10yr').innerText = "+" + blended_10.toFixed(1) + "% CAGR";
            
            if (activeGuidedStep === 1) {
                setTimeout(() => { triggerStepFocus(2); }, 1500);
            }
        }

        function hydrateFunnel() {
            try {
                const saved = localStorage.getItem(storageKey);
                if (saved) {
                    const state = JSON.parse(saved);
                    if (state.age) document.getElementById('current_age').value = state.age;
                    if (state.income) document.getElementById('inc_salary').value = state.income;
                    
                    if (state.debt) {
                        const total_debt = state.debt;
                        document.getElementById('lia_home').value = total_debt;
                        document.getElementById('lia_other').value = 0;
                    }
                    if (state.assets) {
                        const liquid_assets = state.assets;
                        document.getElementById('ast_demat').value = Math.round(liquid_assets * 0.50);
                        document.getElementById('ast_fd').value = Math.round(liquid_assets * 0.40);
                        document.getElementById('ast_cash').value = Math.round(liquid_assets * 0.10);
                    }
                    if (state.house) {
                        document.getElementById('ast_re').value = state.house;
                    }
                    if (state.burn) {
                        const baseline_burn = state.burn;
                        document.getElementById('exp_rent_emi').value = Math.round(baseline_burn * 0.40);
                        document.getElementById('exp_other_emi').value = Math.round(baseline_burn * 0.10);
                        document.getElementById('exp_food_kirana').value = Math.round(baseline_burn * 0.20);
                        document.getElementById('exp_utilities').value = Math.round(baseline_burn * 0.06);
                        document.getElementById('exp_domestic_help').value = Math.round(baseline_burn * 0.05);
                        document.getElementById('exp_fuel_commute').value = Math.round(baseline_burn * 0.09);
                        document.getElementById('exp_dining_out').value = Math.round(baseline_burn * 0.06);
                        document.getElementById('exp_misc_buffer').value = Math.round(baseline_burn * 0.04);
                    }
                }
            } catch(e) { console.error("Funnel parsing bypassed safely:", e); }
        }

        const active_ids = [
            'current_age', 'exp_rent_emi', 'exp_other_emi', 'exp_food_kirana', 'exp_utilities', 
            'exp_domestic_help', 'exp_fuel_commute', 'exp_dining_out', 'exp_misc_buffer', 
            'inc_salary', 'ast_demat', 'ast_fd', 'ast_cash', 'ast_re', 'lia_home', 'lia_other'
        ];
        active_ids.forEach(id => { 
            const el = document.getElementById(id); 
            if(el) el.addEventListener('input', calculate); 
        });
        
        hydrateFunnel();
        calculate();

        triggerStepFocus(1);
    </script>
