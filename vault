<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Financial Vault | Premium Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    
    <style>
        :root {
            var(--bg-main): #F8FAFC;
            --bg-card: #FFFFFF;
            --text-main: #0F172A;
            --text-muted: #64748B;
            --border-color: #E2E8F0;
            --accent-safe: #10B981;
            --accent-danger: #EF4444;
            --accent-primary: #2563EB;
        }
        body { background-color: #F8FAFC; color: var(--text-main); font-family: 'Inter', sans-serif; padding: 20px; margin: 0; -webkit-font-smoothing: antialiased; }
        #auth-container { display: flex; justify-content: center; align-items: center; min-height: 80vh; }
        .auth-card { background: var(--bg-card); border: 1px solid var(--border-color); padding: 40px; border-radius: 12px; width: 100%; max-width: 400px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05); }
        .auth-card h2 { margin-top: 0; margin-bottom: 8px; font-size: 1.75rem; font-weight: 700; letter-spacing: -0.02em; }
        .auth-card p { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 24px; }
        .auth-btn { width: 100%; padding: 12px; background: var(--accent-primary); color: white; border: none; border-radius: 6px; font-weight: 600; font-size: 1rem; cursor: pointer; transition: background 0.2s; margin-top: 10px; }
        .auth-btn:hover { background: #1d4ed8; }
        .auth-toggle { text-align: center; margin-top: 20px; font-size: 0.9rem; color: var(--text-muted); }
        .auth-toggle a { color: var(--accent-primary); text-decoration: none; font-weight: 600; cursor: pointer; }
        #app-container { display: none; }
        .container { display: flex; max-width: 1600px; margin: auto; gap: 40px; }
        .sidebar { width: 320px; flex-shrink: 0; background: var(--bg-card); padding: 20px; border-radius: 12px; border: 1px solid var(--border-color); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); box-sizing: border-box; }
        .drawer-btn { background: none; border: none; color: var(--text-muted); width: 100%; text-align: left; padding: 12px 10px; font-size: 1.05rem; cursor: pointer; transition: 0.2s; border-radius: 6px; font-weight: 500; }
        .drawer-btn.active { color: var(--text-main); background: #F8FAFC; font-weight: 600; }
        .drawer-btn:hover:not(.active) { background: #F8FAFC; color: var(--text-main); }
        .drawer { display: none; padding: 15px 5px; }
        .drawer.active { display: block; }
        h1 { font-size: 2.2rem; margin-top: 0; font-weight: 700; color: var(--text-main); letter-spacing: -0.02em; }
        h2 { font-size: 1.25rem; border-bottom: 2px solid var(--border-color); padding-bottom: 10px; margin-top: 40px; display: flex; justify-content: space-between; align-items: center; font-weight: 600; }
        label { display: block; font-size: 0.85rem; color: var(--text-muted); margin-top: 15px; margin-bottom: 6px; font-weight: 500; }
        input[type="email"], input[type="password"], input[type="number"], input[type="range"] { width: 100%; padding: 10px; background: #F8FAFC; border: 1px solid var(--border-color); color: var(--text-main); border-radius: 6px; box-sizing: border-box; font-size: 1rem; }
        input[type="number"], input[type="range"] { font-family: 'JetBrains Mono', monospace; }
        input:focus { outline: none; border-color: var(--accent-primary); box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1); }
        .indian-words { color: var(--accent-primary); font-size: 0.8rem; margin-top: 6px; margin-bottom: 15px; font-weight: 500; }
        .reset-btn { background: #F8FAFC; color: var(--text-main); border: 1px solid var(--border-color); padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 0.9rem; font-weight: 500; }
        .reset-btn:hover { background: #E2E8F0; }
        .logout-btn { background: none; border: 1px solid var(--border-color); color: var(--text-muted); padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 0.85rem; font-weight: 500; }
        .logout-btn:hover { background: #F8FAFC; color: var(--text-main); }
        .age-container { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .age-input { width: 250px; background: var(--bg-card); padding: 15px; border-radius: 8px; border: 1px solid var(--border-color); }
        .crisis-text { font-weight: 600; font-size: 0.85rem; margin-top: 6px; display: block; }
        .main { flex-grow: 1; }
        .slider-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 20px; }
        .metric-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }
        .hero-banner { border-radius: 12px; padding: 24px; text-align: center; margin-bottom: 25px; border: 2px dashed var(--border-color); transition: all 0.3s; }
        .hero-title { font-size: 2.5rem; font-weight: 800; margin: 0; letter-spacing: -0.02em; }
        .hero-subtitle { font-size: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
        .metric-card { background: var(--bg-card); padding: 24px; border-radius: 12px; border: 1px solid var(--border-color); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }
        .metric-value { font-size: 2.2rem; font-weight: 800; color: var(--text-main); margin: 5px 0; font-family: 'JetBrains Mono', monospace; letter-spacing: -1px; }
        table { width: 100%; border-collapse: collapse; margin-top: 15px; background: var(--bg-card); border-radius: 8px; overflow: hidden; border: 1px solid var(--border-color); }
        th, td { padding: 14px 15px; text-align: right; border-bottom: 1px solid var(--border-color); }
        th { text-align: right; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; background: #F8FAFC; }
        th:first-child, td:first-child { text-align: left; }
        td { font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; }
        td:first-child { font-family: 'Inter', sans-serif; font-weight: 500; font-size: 0.95rem; }
        .warning-box { background: #FFFBEB; border: 1px solid #F59E0B; color: #92400E; padding: 15px 20px; border-radius: 8px; display: flex; align-items: center; gap: 20px; margin-bottom: 30px; }
    </style>
</head>
<body>

    <div id="auth-container">
        <div class="auth-card">
            <h2 id="auth-title">Sign In</h2>
            <p id="auth-subtitle">Access your Networth Vault.</p>
            
            <label>Email Address</label>
            <input type="email" id="auth-email" placeholder="name@domain.com">
            
            <label>Password (Min. 6 characters)</label>
            <input type="password" id="auth-password" placeholder="••••••••">
            
            <button class="auth-btn" id="btn-submit-auth">Sign In</button>
            
            <div class="auth-toggle">
                <span id="auth-toggle-text">Don't have an account?</span> 
                <a id="btn-toggle-mode">Sign up</a>
            </div>
        </div>
    </div>

    <div id="app-container">
        <div class="container">
            <div class="sidebar">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                    <h2 style="margin:0; border: none; padding-bottom: 0;">🛡️ Networth Vault</h2>
                    <button class="logout-btn" id="btn-logout">Exit</button>
                </div>
                <p style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.4; margin-top:0; margin-bottom:25px;">Premium Analytics Workspace Active.</p>
                
                <button class="drawer-btn active" id="nav-costs">📉 1. Your Current Cost</button>
                <button class="drawer-btn" id="nav-money">💰 2. Your Assets</button>
                <button class="drawer-btn" id="nav-loans">⚠️ 3. Your Liabilities</button>

                <div id="drawer-costs" class="drawer active">
                    <label>Standard Monthly Expenses (₹)</label>
                    <input type="number" id="monthly_burn" value="100000" step="10000">
                    <div id="words_monthly_burn" class="indian-words"></div>
                    <label>Annual Large Expenses (₹)</label>
                    <input type="number" id="annual_spikes" value="240000" step="20000">
                    <div id="words_annual_spikes" class="indian-words"></div>
                </div>

                <div id="drawer-money" class="drawer">
                    <label>Stocks & Mutual Funds (₹)</label>
                    <input type="number" id="equity_base" value="12000000" step="500000">
                    <div id="words_equity_base" class="indian-words"></div>
                    <label>Fixed Deposits / EPF / PPF (₹)</label>
                    <input type="number" id="debt_base" value="9500000" step="500000">
                    <div id="words_debt_base" class="indian-words"></div>
                    <label>Gold & Silver (₹)</label>
                    <input type="number" id="metals_base" value="3000000" step="100000">
                    <div id="words_metals_base" class="indian-words"></div>
                    <label>Current Home Market Value (₹)</label>
                    <input type="number" id="real_estate_base" value="15000000" step="1000000">
                    <div id="words_real_estate_base" class="indian-words"></div>
                </div>

                <div id="drawer-loans" class="drawer">
                    <label>Home Loan Balance Outstanding (₹)</label>
                    <input type="number" id="home_loan_base" value="4500000" step="500000">
                    <div id="words_home_loan_base" class="indian-words"></div>
                    <label>Other Loans (₹)</label>
                    <input type="number" id="other_loan_base" value="800000" step="100000">
                    <div id="words_other_loan_base" class="indian-words"></div>
                </div>
            </div>
            
            <div class="main">
                <div class="age-container">
                    <div>
                        <h1>The Pink Slip Index <span style="font-size: 1rem; color: var(--accent-primary); background: #EFF6FF; padding: 4px 8px; border-radius: 4px; margin-left: 10px;">PREMIUM</span></h1>
                        <p style="color: var(--text-muted); margin: 0; font-size: 0.95rem;">Secured quantitative environment.</p>
                    </div>
                    <div class="age-input">
                        <label style="margin-top: 0; color: var(--text-main);">⚡ Enter Your Current Age</label>
                        <input type="number" id="current_age" value="40" style="background: var(--bg-card);">
                    </div>
                </div>
                
                <h2>🚨 Stress Test <button class="reset-btn" id="btn-reset-sliders">🔄 Reset Parameters</button></h2>
                
                <div class="slider-grid">
                    <div><label>Stocks Collapse/Rally (%)</label><input type="range" id="equity_shift" min="-70" max="50" value="0" step="5"><span id="txt_equity" class="crisis-text"></span></div>
                    <div><label>Gold/Silver Shift (%)</label><input type="range" id="metals_shift" min="-70" max="120" value="0" step="5"><span id="txt_metals" class="crisis-text"></span></div>
                    <div><label>Monthly Expense Shock (₹)</label><input type="range" id="expense_shock" min="0" max="150000" step="10000" value="0"><span id="txt_expense" class="crisis-text"></span></div>
                    <div><label>Liquidate Home (₹ Realized)</label><input type="range" id="re_liquidation" min="0" max="15000000" step="1000000" value="0"><span id="txt_re" class="crisis-text"></span></div>
                </div>

                <div id="rent_warning" class="warning-box" style="display: none;">
                    <div style="flex-grow: 1;">⚠️ <strong>FORCED TENANCY ALERT:</strong> Indefinite rental outflows are added to the simulation loop.</div>
                    <div style="width: 250px;"><label style="color: #92400E; margin-top: 0;">Emergency Monthly Rent (₹)</label><input type="number" id="simulated_monthly_rent" value="0" step="5000" style="background: #FEF3C7; border-color: #F59E0B; color: #92400E;"></div>
                </div>

                <h2 style="margin-top: 30px;">📊 Portfolio Reality</h2>
                <div id="banner" class="hero-banner"><div id="status_text" class="hero-subtitle"></div><div id="hero_text" class="hero-title"></div></div>

                <div class="metric-grid">
                    <div class="metric-card"><div style="color:var(--text-muted); font-weight:600; text-transform:uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">Immediate Shield (Liquid Money)</div><div class="metric-value"><span id="val_months" style="color: var(--accent-safe);"></span> <span style="font-size: 1.1rem; color: var(--text-muted); font-family: 'Inter', sans-serif;">Mos</span> <span style="font-size: 1.5rem; color: var(--accent-primary);" id="val_years"></span></div></div>
                    <div class="metric-card"><div style="color:var(--text-muted); font-weight:600; text-transform:uppercase; font-size: 0.85rem; letter-spacing: 0.05em;">Total Shield (Total Estate)</div><div class="metric-value" id="val_total" style="color: var(--text-main);"></div></div>
                </div>

                <h2 style="margin-top: 30px;">🔄 Networth Vault Impact</h2>
                <table>
                    <thead><tr><th>Asset Type</th><th>Your Baseline</th><th>Crisis Test Impact</th><th>Survival Portfolio Value</th></tr></thead>
                    <tbody id="vault_table"></tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        const _supabase = supabase.createClient("https://cplwzsssvkrijnwisjdn.supabase.co", "sb_publishable_WGaGuGrAs-Oi-y6n3n2saw_AFrcLz52");

        _supabase.auth.onAuthStateChange((event, session) => {
            if (session) {
                document.getElementById('auth-container').style.display = 'none';
                document.getElementById('app-container').style.display = 'block';
                calculate();
            } else {
                document.getElementById('auth-container').style.display = 'flex';
                document.getElementById('app-container').style.display = 'none';
            }
        });

        // Toggle UI Logic
        let isLoginMode = true;
        const btnSubmit = document.getElementById('btn-submit-auth');
        const authTitle = document.getElementById('auth-title');
        const authSubtitle = document.getElementById('auth-subtitle');
        const toggleText = document.getElementById('auth-toggle-text');
        const btnToggle = document.getElementById('btn-toggle-mode');

        function switchMode() {
            isLoginMode = !isLoginMode;
            if(isLoginMode) {
                authTitle.innerText = "Sign In";
                authSubtitle.innerText = "Access your Networth Vault.";
                btnSubmit.innerText = "Sign In";
                toggleText.innerText = "Don't have an account?";
                btnToggle.innerText = "Sign up";
            } else {
                authTitle.innerText = "Create Account";
                authSubtitle.innerText = "Initialize your secure vault profile.";
                btnSubmit.innerText = "Create Account";
                toggleText.innerText = "Already have an account?";
                btnToggle.innerText = "Sign in";
            }
        }

        btnToggle.addEventListener('click', (e) => {
            e.preventDefault();
            switchMode();
        });

        // Fixed Submission Logic
        btnSubmit.addEventListener('click', async () => {
            const email = document.getElementById('auth-email').value.trim();
            const password = document.getElementById('auth-password').value;
            
            if(!email || !password) return alert('Credentials cannot be empty.');
            
            if(isLoginMode) {
                const { error } = await _supabase.auth.signInWithPassword({ email, password });
                if(error) alert(error.message);
            } else {
                // Sign Up flow with proper user feedback
                const { error } = await _supabase.auth.signUp({ email, password });
                
                if(error) {
                    alert(error.message);
                } else {
                    alert("Success! Check your email inbox (and spam folder) for the confirmation link to activate your profile.");
                    switchMode(); // Flip back to login screen while they check their email
                }
            }
        });

        document.getElementById('btn-logout').addEventListener('click', async () => { await _supabase.auth.signOut(); });

        const bindDrawer = (btnId, drawerId) => {
            document.getElementById(btnId).addEventListener('click', (e) => {
                document.querySelectorAll('.drawer').forEach(d => d.classList.remove('active'));
                document.querySelectorAll('.drawer-btn').forEach(b => b.classList.remove('active'));
                document.getElementById(drawerId).classList.add('active');
                e.target.classList.add('active');
            });
        };
        bindDrawer('nav-costs', 'drawer-costs');
        bindDrawer('nav-money', 'drawer-money');
        bindDrawer('nav-loans', 'drawer-loans');

        document.getElementById('btn-reset-sliders').addEventListener('click', () => {
            document.getElementById('equity_shift').value = 0; document.getElementById('metals_shift').value = 0; document.getElementById('expense_shock').value = 0; document.getElementById('re_liquidation').value = 0; calculate();
        });

        const fmt = (num) => new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 }).format(num);

        function formatIndianWords(number) {
            if (number === 0) return "Zero Rupees";
            const crores = Math.floor(number / 10000000); let remainder = number % 10000000; const lakhs = Math.floor(remainder / 100000); remainder = remainder % 100000; const thousands = Math.floor(remainder / 1000); const rupees = remainder % 1000;
            let result = [];
            if (crores > 0) result.push(`${crores} Crore${crores > 1 ? 's' : ''}`); if (lakhs > 0) result.push(`${lakhs} Lakh${lakhs > 1 ? 's' : ''}`); if (thousands > 0) result.push(`${thousands} Thousand`); if (rupees > 0 || result.length === 0) result.push(`${rupees} Rupee${rupees > 1 || rupees === 0 ? 's' : ''}`);
            return result.join(" ");
        }

        async function calculate() {
            if(document.getElementById('app-container').style.display === 'none' || !document.getElementById('monthly_burn')) return;
            document.getElementById('re_liquidation').max = document.getElementById('real_estate_base').value;
            const keys = ['current_age', 'monthly_burn', 'annual_spikes', 'equity_base', 'debt_base', 'metals_base', 'real_estate_base', 'home_loan_base', 'other_loan_base', 'equity_shift', 'metals_shift', 'expense_shock', 're_liquidation', 'simulated_monthly_rent'];
            let payload = {}; keys.forEach(k => payload[k] = Number(document.getElementById(k).value));
            const suffixMap = { monthly_burn: " per month", annual_spikes: " per year" };
            ['monthly_burn', 'annual_spikes', 'equity_base', 'debt_base', 'metals_base', 'real_estate_base', 'home_loan_base', 'other_loan_base'].forEach(id => { document.getElementById('words_' + id).innerHTML = "👉 " + formatIndianWords(payload[id]) + (suffixMap[id] || ""); });

            const eq = payload.equity_shift; document.getElementById('txt_equity').innerHTML = eq === 0 ? '<span style="color:var(--text-muted)">🟢 Normal Markets</span>' : eq < -30 ? '<span style="color:var(--accent-danger)">🚨 Global Crisis</span>' : eq < -10 ? '<span style="color:#f97316">🔥 Severe Market Crash</span>' : eq < 0 ? '<span style="color:#f59e0b">⚠️ Market Correction</span>' : '<span style="color:var(--accent-safe)">🚀 Bull Run</span>';
            const met = payload.metals_shift; document.getElementById('txt_metals').innerHTML = met === 0 ? '<span style="color:var(--text-muted)">🟢 Normal Markets</span>' : met < -30 ? '<span style="color:var(--accent-danger)">🚨 Global Crisis</span>' : met < -10 ? '<span style="color:#f97316">🔥 Severe Market Crash</span>' : met < 0 ? '<span style="color:#f59e0b">⚠️ Market Correction</span>' : '<span style="color:var(--accent-safe)">🚀 Bull Run</span>';
            const exp = payload.expense_shock; document.getElementById('txt_expense').innerHTML = exp > 0 ? `<span style="color:#f97316">💸 +₹${fmt(exp)}/mo Added Outflow</span>` : '<span style="color:var(--text-muted)">🟢 Normal Expenses</span>';
            const re = payload.re_liquidation; const re_pct = payload.real_estate_base > 0 ? (re / payload.real_estate_base) * 100 : 0; document.getElementById('txt_re').innerHTML = re === 0 ? '<span style="color:var(--accent-safe)">🏡 Home Protected</span>' : re_pct <= 25 ? `<span style="color:#f59e0b">⚠️ Stress Refinance (${fmt(re_pct)}%)</span>` : re_pct <= 75 ? `<span style="color:#f97316">🔥 Forced Downsize (${fmt(re_pct)}%)</span>` : `<span style="color:var(--accent-danger)">🚨 Absolute Liquidation (${fmt(re_pct)}%)</span>`;

            const rentWarning = document.getElementById('rent_warning'); const rentInput = document.getElementById('simulated_monthly_rent');
            if (re > 0) {
                if (rentWarning.style.display === 'none') { rentInput.value = Math.round((payload.real_estate_base * 0.03) / 12); payload.simulated_monthly_rent = Number(rentInput.value); }
                rentWarning.style.display = 'flex';
            } else { rentWarning.style.display = 'none'; payload.simulated_monthly_rent = 0; rentInput.value = 0; }

            const res = await fetch('/simulate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            const data = await res.json();
            
            const banner = document.getElementById('banner'); banner.style.backgroundColor = data.banner_bg; banner.style.borderColor = data.banner_border; banner.style.color = data.banner_text;
            document.getElementById('status_text').innerText = data.status_label; document.getElementById('hero_text').innerText = data.hero_title;
            document.getElementById('val_months').innerText = fmt(data.runway_months); document.getElementById('val_years').innerText = `(${data.runway_years} Yrs)`; document.getElementById('val_total').innerText = `Life Secured until Age ${data.max_safe_age}`;

            document.getElementById('vault_table').innerHTML = `
                <tr><td>Stocks & Mutual Funds</td><td>${fmt(payload.equity_base)}</td><td><span style="color: ${data.disp_equity - payload.equity_base >= 0 ? 'var(--accent-safe)' : 'var(--accent-danger)'}">${data.disp_equity - payload.equity_base > 0 ? '+' : ''}${fmt(data.disp_equity - payload.equity_base)}</span></td><td>${fmt(data.disp_equity)}</td></tr>
                <tr><td>Fixed Income & Deposits</td><td>${fmt(payload.debt_base)}</td><td><span style="color: var(--text-muted)">0</span></td><td>${fmt(data.sim_debt_survival)}</td></tr>
                <tr><td>Gold & Silver</td><td>${fmt(payload.metals_base)}</td><td><span style="color: ${data.disp_metals - payload.metals_base >= 0 ? 'var(--accent-safe)' : 'var(--accent-danger)'}">${data.disp_metals - payload.metals_base > 0 ? '+' : ''}${fmt(data.disp_metals - payload.metals_base)}</span></td><td>${fmt(data.disp_metals)}</td></tr>
                <tr><td>Remaining Home Value</td><td>${fmt(payload.real_estate_base)}</td><td><span style="color: var(--accent-danger)">-${fmt(payload.re_liquidation)}</span></td><td>${fmt(data.adj_home_value)}</td></tr>
                <tr><td style="color:#D97706; font-weight: 600;">⚠️ Outstanding Loans (Debt)</td><td style="color:#D97706;">${fmt(data.total_debts)}</td><td><span style="color: var(--text-muted)">0</span></td><td style="color:#D97706;">${fmt(data.total_debts)}</td></tr>
            `;
        }

        const inputs = ['current_age', 'monthly_burn', 'annual_spikes', 'equity_base', 'debt_base', 'metals_base', 'real_estate_base', 'home_loan_base', 'other_loan_base', 'equity_shift', 'metals_shift', 'expense_shock', 're_liquidation', 'simulated_monthly_rent'];
        inputs.forEach(id => document.getElementById(id).addEventListener('input', calculate));
    </script>
</body>
</html>
