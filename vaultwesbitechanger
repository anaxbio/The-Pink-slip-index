                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                            <div class="bg-zinc-950/40 p-4 rounded-xl border border-zinc-900">
                                <span class="text-zinc-500 text-[10px] font-bold uppercase tracking-wider">Total Invested</span>
                                <p class="text-xl font-extrabold font-mono-custom text-white mt-1" id="kpi-cockpit-invested">₹0.00</p>
                            </div>
                            <div class="bg-zinc-950/40 p-4 rounded-xl border border-zinc-900">
                                <span class="text-zinc-500 text-[10px] font-bold uppercase tracking-wider">Market Value</span>
                                <p class="text-xl font-extrabold font-mono-custom text-emerald-400 mt-1" id="kpi-cockpit-value">₹0.00</p>
                            </div>
                            <div class="bg-zinc-950/40 p-4 rounded-xl border border-zinc-900 col-span-2">
                                <span class="text-zinc-500 text-[10px] font-bold uppercase tracking-wider">Unrealized PnL</span>
                                <p class="text-xl font-extrabold font-mono-custom text-zinc-300 mt-1" id="kpi-cockpit-pnl">₹0.00 <span class="text-xs text-zinc-500">(0.00%)</span></p>
                            </div>
                        </div>
                        <div class="h-64 flex items-center justify-center border border-dashed border-zinc-800 rounded-xl bg-zinc-950/20 text-zinc-500 text-xs">
                            [ Area Chart: Real-time Consolidated Portfolio Trajectory ]
                        </div>
                    </div>
                    <div class="glass-panel p-6 rounded-2xl col-span-1 flex flex-col items-center">
                        <h3 class="text-sm font-bold text-white mb-4 w-full uppercase tracking-wide">Asset Allocation</h3>
                        <div class="relative w-48 h-48 mb-4">
                            <canvas id="allocationPieChart"></canvas>
                        </div>
                        <div class="w-full space-y-2 mt-2" id="allocation-legend"></div>
                    </div>
                </div>
            </section>

            <!-- TAB 2: Master Portfolio -->
            <section id="tab-portfolio" class="hidden space-y-6">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                    <div>
                        <h2 class="text-xl font-bold tracking-tight text-white flex items-center gap-2">
                            <i data-lucide="briefcase" class="text-emerald-500 w-5 h-5"></i> Master Portfolio & Margin Shield
                        </h2>
                        <p class="text-xs text-zinc-500 mt-1">Consolidated positions ledger, stress-testing pricing panel, and safety margin indicators.</p>
                    </div>
                    <div class="flex items-center gap-2 flex-wrap">
                        <span class="text-xs text-zinc-500 font-bold uppercase font-mono-custom">Stress override:</span>
                        <div class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="override-active-toggle" onchange="toggleManualOverride()" class="sr-only peer">
                            <div class="w-9 h-5 bg-zinc-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-zinc-400 after:border-zinc-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-emerald-600 peer-checked:after:bg-zinc-950"></div>
                        </div>
                        <button onclick="loadPortfolioLedger()" class="px-3 py-2 rounded-lg bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 text-xs text-zinc-400 hover:text-zinc-200 transition-all flex items-center gap-1.5">
                            <i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i> Sync Ledger
                        </button>
                    </div>
                </div>

                <!-- Manual Price Override Stress Board -->
                <div id="stress-override-panel" class="hidden glass-panel p-6 rounded-2xl border border-zinc-800/80 bg-zinc-950/40">
                    <div class="flex items-center gap-2 text-rose-400 text-xs font-bold uppercase tracking-wider mb-4">
                        <i data-lucide="shield-alert" class="w-4 h-4"></i> Active Stress Test Price override panel
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="override-inputs-container">
                        <!-- Dynamic stress inputs generated via JS -->
                    </div>
                </div>

                <!-- Global Aggregate Cards -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="glass-panel p-6 rounded-2xl bg-zinc-900/30">
                        <p class="text-zinc-500 text-xs font-bold uppercase tracking-wider">Gold Net MTM P&L</p>
                        <p class="text-2xl font-extrabold font-mono-custom text-white mt-1" id="kpi-gold-pnl">₹0.00</p>
                    </div>
                    <div class="glass-panel p-6 rounded-2xl bg-zinc-900/30">
                        <p class="text-zinc-500 text-xs font-bold uppercase tracking-wider">Silver Net MTM P&L</p>
                        <p class="text-2xl font-extrabold font-mono-custom text-white mt-1" id="kpi-silver-pnl">₹0.00</p>
                    </div>
                    <div class="glass-panel p-6 rounded-2xl bg-zinc-950/40 border-emerald-500/20">
                        <p class="text-zinc-500 text-xs font-bold uppercase tracking-wider">Consolidated Net P&L</p>
                        <p class="text-2xl font-extrabold font-mono-custom text-emerald-400 mt-1" id="kpi-total-net-pnl">₹0.00</p>
                    </div>
                </div>

                <!-- RESTORED: Individual Account Ledgers with 10% Cash Margin Shield -->
                <div class="space-y-3">
                    <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-widest flex items-center gap-1.5"><i data-lucide="shield-check" class="text-emerald-500 w-4 h-4"></i> Individual Account Ledger Shields</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="individual-ledger-cards">
                        <!-- Account Nodes dynamically loaded from ledger groupings -->
                    </div>
                </div>

                <!-- RESTORED: Exit Desk Form -->
                <div class="glass-panel p-6 rounded-2xl border border-zinc-800 bg-zinc-950/40 space-y-4">
                    <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-widest flex items-center gap-1.5"><i data-lucide="log-out" class="text-rose-500 w-4 h-4"></i> Exit Desk (Position Liquidations)</h3>
                    <div class="grid grid-cols-1 lg:grid-cols-4 gap-4 items-end">
                        <div>
                            <label class="block text-xs font-semibold text-zinc-500 mb-1.5">Asset Target</label>
                            <select id="exit-asset-select" onchange="updateExitDeskPreview()" class="w-full px-3 py-2 rounded-lg text-sm glass-panel-input text-zinc-200"></select>
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-zinc-500 mb-1.5">Quantity to Liquidate</label>
                            <input type="number" id="exit-qty-input" oninput="updateExitDeskPreview()" class="w-full px-3 py-2 rounded-lg text-sm glass-panel-input text-zinc-200" min="0" step="any">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-zinc-500 mb-1.5">Exit Execution Price</label>
                            <input type="number" id="exit-price-input" oninput="updateExitDeskPreview()" class="w-full px-3 py-2 rounded-lg text-sm glass-panel-input text-zinc-200" min="0" step="any">
                        </div>
                        <div>
                            <button onclick="commitExitDeskTrade()" class="w-full py-2 bg-rose-600 hover:bg-rose-500 text-white text-xs font-bold tracking-wider rounded-lg transition-all flex items-center justify-center gap-1.5 h-[38px] shadow shadow-rose-950/30">
                                <i data-lucide="zap" class="w-4 h-4"></i> EXECUTE EXIT & LOG
                            </button>
                        </div>
                    </div>
                    <div id="exit-preview-box" class="hidden p-3 rounded-lg bg-zinc-900/60 border border-zinc-800 text-xs flex justify-between items-center font-mono-custom">
                        <span class="text-zinc-500">Preview:</span>
                        <span class="text-zinc-300">Exit size: <span class="font-bold text-white" id="exit-preview-qty">0.00</span> | Estimated Realized P&L: <span class="font-bold" id="exit-preview-pnl">₹0.00</span></span>
                    </div>
                </div>

                <!-- RESTORED: Three Isolated st.data_editor equivalent tables -->
                <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
                    
                    <!-- Table 1: Gold SGBs (Asset Class: SGB) -->
                    <div class="glass-panel rounded-2xl border border-zinc-800 flex flex-col min-h-[400px]">
                        <div class="bg-zinc-950/60 px-5 py-3 border-b border-zinc-800 flex items-center justify-between">
                            <h3 class="text-xs font-bold text-white uppercase tracking-widest font-mono-custom flex items-center gap-1.5"><i data-lucide="gold" class="w-4 h-4 text-amber-500"></i> Gold SGBs Table</h3>
                            <button onclick="addNewLedgerRow('SGB')" class="px-2.5 py-1 text-[10px] font-bold rounded bg-emerald-600/10 hover:bg-emerald-600/20 border border-emerald-500/20 text-emerald-400 transition-all flex items-center gap-1"><i data-lucide="plus" class="w-3 h-3"></i> Add Row</button>
                        </div>
                        <div class="overflow-x-auto flex-1">
