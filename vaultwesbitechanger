                                        <th class="px-3 py-2">Tranche</th>
                                        <th class="px-3 py-2 text-right">Qty</th>
                                        <th class="px-3 py-2 text-right">Avg Px</th>
                                        <th class="px-3 py-2 text-right">Live</th>
                                        <th class="px-3 py-2 text-center">Ctrl</th>
                                    </tr>
                                </thead>
                                <tbody id="sgb-editor-rows" class="divide-y divide-zinc-900"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Table 2: Silver ETFs (Asset Class: Silver ETF) -->
                    <div class="glass-panel rounded-2xl border border-zinc-800 flex flex-col min-h-[400px]">
                        <div class="bg-zinc-950/60 px-5 py-3 border-b border-zinc-800 flex items-center justify-between">
                            <h3 class="text-xs font-bold text-white uppercase tracking-widest font-mono-custom flex items-center gap-1.5"><i data-lucide="database" class="w-4 h-4 text-zinc-400"></i> Silver ETFs Table</h3>
                            <button onclick="addNewLedgerRow('Silver ETF')" class="px-2.5 py-1 text-[10px] font-bold rounded bg-emerald-600/10 hover:bg-emerald-600/20 border border-emerald-500/20 text-emerald-400 transition-all flex items-center gap-1"><i data-lucide="plus" class="w-3 h-3"></i> Add Row</button>
                        </div>
                        <div class="overflow-x-auto flex-1">
                            <table class="w-full text-left border-collapse text-xs font-mono-custom">
                                <thead>
                                    <tr class="bg-zinc-950/20 text-zinc-500 border-b border-zinc-850">
