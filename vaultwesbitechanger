        function calculateContangoSpreads() {
            const goldCurves = ["GOLDPETAL30OCT26FUT", "GOLDPETAL27NOV26FUT", "GOLDPETAL18DEC26FUT"];
            const goldBody = document.getElementById('gold-contango-rows');
            goldBody.innerHTML = '';

            for (let i = 0; i < goldCurves.length - 1; i++) {
                const c_curr = goldCurves[i];
                const c_next = goldCurves[i+1];

                const ltp_c = getEffectivePrice(c_curr, true);
                const ltp_n = getEffectivePrice(c_next, true);

                const dateCurr = parseExpiries(c_curr);
                const dateNext = parseExpiries(c_next);
                const daysDiff = Math.max(1, Math.round((dateNext - dateCurr) / (1000 * 60 * 60 * 24)));

                const rawSpread = ltp_n - ltp_c;
                const annYield = (rawSpread / ltp_c) * (365.0 / daysDiff) * 100.0;

                goldBody.innerHTML += `
                    <tr class="hover:bg-zinc-900/20 transition-all">
                        <td class="px-5 py-3 text-white font-semibold">${c_curr.substring(9, 12)} ➡️ ${c_next.substring(9, 12)}</td>
                        <td class="px-5 py-3 text-right text-zinc-300 font-bold">₹ ${rawSpread.toFixed(2)}</td>
                        <td class="px-5 py-3 text-right text-emerald-400 font-extrabold font-mono-custom">${annYield.toFixed(2)}%</td>
                    </tr>
                `;
            }

            const silverCurves = ["SILVERMIC30OCT26FUT", "SILVERMIC27NOV26FUT"];
            const silverBody = document.getElementById('silver-contango-rows');
            silverBody.innerHTML = '';

            for (let i = 0; i < silverCurves.length - 1; i++) {
                const c_curr = silverCurves[i];
                const c_next = silverCurves[i+1];

                const ltp_c = getEffectivePrice(c_curr, true);
                const ltp_n = getEffectivePrice(c_next, true);

                const dateCurr = parseExpiries(c_curr);
                const dateNext = parseExpiries(c_next);
                const daysDiff = Math.max(1, Math.round((dateNext - dateCurr) / (1000 * 60 * 60 * 24)));

                const rawSpread = ltp_n - ltp_c;
                const annYield = (rawSpread / ltp_c) * (365.0 / daysDiff) * 100.0;

                silverBody.innerHTML += `
                    <tr class="hover:bg-zinc-900/20 transition-all">
                        <td class="px-5 py-3 text-white font-semibold">${c_curr.substring(9, 12)} ➡️ ${c_next.substring(9, 12)}</td>
                        <td class="px-5 py-3 text-right text-zinc-300 font-bold">₹ ${rawSpread.toFixed(0)} /kg</td>
                        <td class="px-5 py-3 text-right text-emerald-400 font-extrabold font-mono-custom">${annYield.toFixed(2)}%</td>
                    </tr>
                `;
            }
        }

        function parseExpiries(sym) {
            const match = sym.match(/(\d{2}[A-Z]{3}\d{2})/);
            if (match) {
                const parts = match[1];
                const day = parseInt(parts.substring(0,2));
                const monthStr = parts.substring(2,5);
                const year = parseInt("20" + parts.substring(5,7));
                
                const months = {"OCT":9, "NOV":10, "DEC":11, "JAN":0, "FEB":1, "MAR":2};
                return new Date(year, months[monthStr], day);
            }
            return new Date();
        }

        function scanArbitrageMatrix() {
            const sgbTargets = document.getElementById('arb-sgb-input').value.split(',').map(s => s.trim());
            const futureTarget = document.getElementById('arb-future-input').value.trim();
            const tradeVolume = parseFloat(document.getElementById('arb-volume-input').value) || 24;
            const frictionPerG = parseFloat(document.getElementById('arb-friction-input').value) || 15.0;

            const matrixBody = document.getElementById('arb-matrix-rows');
            matrixBody.innerHTML = '';

            const futureTick = mcx_mkt[futureTarget];
            const octPetalBid = futureTick ? (futureTick.bids[0] ? futureTick.bids[0][0] : futureTick.ltp) : 7650.0;

            let alertTriggered = false;
            const executionOrdersContainer = document.getElementById('execution-orders-container');
            executionOrdersContainer.innerHTML = '';

            sgbTargets.forEach(sgbSym => {
                const sgbAsk = getEffectivePrice(sgbSym, false);
                if (sgbAsk > 0) {
                    const params = static_horizons[sgbSym] || { months: 6, rolls: 1 };
                    
                    const rawSpread = octPetalBid - sgbAsk;
                    const rollCredit = params.rolls * 180.0; // Dynamic roll credits
                    const grossContangoGain = rawSpread + rollCredit;
                    
                    const orderBrokerageImpact = 20.0 / tradeVolume;
                    const totalNetGain = grossContangoGain - frictionPerG - orderBrokerageImpact;
                    
                    const netAnnYield = (totalNetGain / sgbAsk) * (12.0 / params.months) * 100.0;
                    const isAlert = netAnnYield >= 18.0;

                    let rowClass = "hover:bg-zinc-900/20";
                    let statusHtml = `<span class="text-zinc-500 font-bold">Hold</span>`;
                    
                    if (isAlert) {
                        alertTriggered = true;
                        rowClass = "bg-rose-950/15 text-rose-400 font-bold border-l-2 border-rose-500";
                        statusHtml = `<span class="px-2.5 py-0.5 rounded bg-rose-500/10 border border-rose-500/20 text-rose-400 text-[10px] animate-pulse">🚨 EXECUTE</span>`;

                        executionOrdersContainer.innerHTML += `
                            <div class="glass-panel p-4 rounded-xl border border-rose-500/20 bg-rose-950/10 text-xs font-mono-custom">
                                <h4 class="font-bold text-rose-400 mb-2 uppercase flex items-center gap-1.5"><i data-lucide="shield-alert" class="w-4 h-4"></i> Double-Sided Execution Path for ${sgbSym}</h4>
                                <p class="text-zinc-300">🟢 <span class="font-bold text-emerald-400">LONG SIDE:</span> Acquire physical units of <span class="font-bold text-white">${sgbSym}</span> on NSE exchange ask.</p>
                                <p class="text-zinc-300 mt-1.5">🔴 <span class="font-bold text-rose-400">SHORT SIDE:</span> Sell offsetting contracts of <span class="font-bold text-white">${futureTarget}</span> at ₹ ${octPetalBid.toLocaleString('en-IN')} on MCX.</p>
                            </div>
                        `;
                    }

                    matrixBody.innerHTML += `
                        <tr class="${rowClass} transition-all">
                            <td class="px-5 py-3 text-white font-extrabold">${sgbSym} vs ${futureTarget}</td>
                            <td class="px-5 py-3 text-right">₹ ${sgbAsk.toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                            <td class="px-5 py-3 text-right">₹ ${octPetalBid.toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                            <td class="px-5 py-3 text-right">₹ ${rawSpread.toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                            <td class="px-5 py-3 text-right">₹ ${rollCredit.toLocaleString('en-IN', {maximumFractionDigits:0})}</td>
                            <td class="px-5 py-3 text-right">₹ ${(frictionPerG + orderBrokerageImpact).toFixed(2)}</td>
                            <td class="px-5 py-3 text-right font-extrabold text-emerald-400">${netAnnYield.toFixed(2)}% p.a.</td>
                            <td class="px-5 py-3 text-center">${statusHtml}</td>
                        </tr>
                    `;
                }
            });

            const banner = document.getElementById('arb-opportunity-banner');
            if (alertTriggered) {
                banner.classList.remove('hidden');
                executionOrdersContainer.classList.remove('hidden');
            } else {
                banner.classList.add('hidden');
                executionOrdersContainer.classList.add('hidden');
            }
            lucide.createIcons();
        }

        // ================= ORDER BOOK DEPTH MAP =================
        function renderDepthMap() {
            const targetSym = document.getElementById('depth-asset-select').value;
            const tick = nse_mkt[targetSym];

            const bidsContainer = document.getElementById('bids-depth-container');
            const asksContainer = document.getElementById('asks-depth-container');

            bidsContainer.innerHTML = '';
            asksContainer.innerHTML = '';

            const ltp = tick ? tick.ltp : 7400.0;
            
            const bestBid = tick ? (tick.bids[0] ? tick.bids[0][0] : ltp - 10) : ltp - 15;
            const bestAsk = tick ? (tick.asks[0] ? tick.asks[0][0] : ltp + 10) : ltp + 15;

            // Render Bids Ladder
            let totalBids = 0;
            for (let i = 0; i < 5; i++) {
                const px = bestBid - (i * 10);
                const qty = Math.round(50 - (i * 8) + (Math.random() * 5));
                totalBids += qty;

                bidsContainer.innerHTML += `
                    <div class="relative py-2 px-3 border border-zinc-900 rounded-lg overflow-hidden bg-zinc-950/20 text-xs">
                        <div class="absolute inset-y-0 left-0 bg-emerald-500/5" style="width: ${Math.min(100, (qty / 150) * 100)}%"></div>
                        <div class="relative flex items-center justify-between z-10">
                            <span class="text-zinc-500">Level ${i+1}</span>
                            <span class="font-bold text-zinc-300 font-mono-custom">${qty} units</span>
                            <span class="font-bold text-emerald-400 font-mono-custom">₹ ${px.toLocaleString('en-IN', {maximumFractionDigits:0})}</span>
                        </div>
                    </div>
                `;
            }

            // Render Asks Ladder
            let totalAsks = 0;
            for (let i = 0; i < 5; i++) {
                const px = bestAsk + (i * 10);
                const qty = Math.round(45 - (i * 7) + (Math.random() * 6));
                totalAsks += qty;

                asksContainer.innerHTML += `
                    <div class="relative py-2 px-3 border border-zinc-900 rounded-lg overflow-hidden bg-zinc-950/20 text-xs">
                        <div class="absolute inset-y-0 right-0 bg-rose-500/5" style="width: ${Math.min(100, (qty / 150) * 100)}%"></div>
                        <div class="relative flex items-center justify-between z-10">
                            <span class="font-bold text-rose-400 font-mono-custom">₹ ${px.toLocaleString('en-IN', {maximumFractionDigits:0})}</span>
                            <span class="font-bold text-zinc-300 font-mono-custom">${qty} units</span>
                            <span class="text-zinc-500">Level ${i+1}</span>
                        </div>
                    </div>
                `;
            }
        }

        // ================= CHART & COCKPIT LOGIC =================
        function initChart() {
            const ctx = document.getElementById('allocationPieChart').getContext('2d');
            allocationChart = new Chart(ctx, {
                type: 'doughnut',
                data: { labels: [], datasets: [{ data: [], backgroundColor: [], borderWidth: 0 }] },
                options: { cutout: '75%', plugins: { legend: { display: false } } }
            });
        }

        async function updateCockpitView() {
            const filter = document.getElementById('cockpit-owner-filter').value;
            try {
                const data = await secureApiRequest('/api/vault/metals_analytics');
                const rawLedger = data.ledger_items || [];

                let filtered = rawLedger;
                if (filter !== "ALL") {
                    filtered = rawLedger.filter(item => item.owner.toUpperCase() === filter.toUpperCase());
                }

                let totalInvested = 0.0;
                let totalValue = 0.0;
                let allocationMap = {};

                filtered.forEach(item => {
                    const qty = parseFloat(item.qty || 0.0);
                    const avgPx = parseFloat(item.avg_price || 0.0);
                    const isMcx = item.asset_class.toUpperCase().includes("MCX") || item.asset_name.includes("FUT");
                    const ltp = getEffectivePrice(item.asset_name, isMcx);

                    const cost = qty * avgPx;
                    let val = qty * ltp;
                    if (isMcx) {
                        val = qty * avgPx + (avgPx - ltp) * qty; 
                    }

                    totalInvested += cost;
                    totalValue += val;

                    const cls = item.asset_class || "Unclassified";
                    allocationMap[cls] = (allocationMap[cls] || 0) + val;
                });

                const pnl = totalValue - totalInvested;
                const pnlPct = totalInvested > 0 ? (pnl / totalInvested) * 100 : 0.0;
                const pnlClass = pnl >= 0 ? 'text-emerald-400' : 'text-rose-400';

                document.getElementById('kpi-cockpit-invested').textContent = `₹ ${totalInvested.toLocaleString('en-IN', {maximumFractionDigits:0})}`;
                document.getElementById('kpi-cockpit-value').textContent = `₹ ${totalValue.toLocaleString('en-IN', {maximumFractionDigits:0})}`;
                document.getElementById('kpi-cockpit-pnl').innerHTML = `₹ ${pnl.toLocaleString('en-IN', {maximumFractionDigits:0})} <span class="text-xs ${pnlClass}">(${pnl >= 0 ? '+' : ''}${pnlPct.toFixed(2)}%)</span>`;

                const labels = Object.keys(allocationMap);
                const chartData = Object.values(allocationMap);
                const bgColors = labels.map((_, i) => `hsl(${(i * 50) % 360}, 70%, 50%)`);

                allocationChart.data.labels = labels;
                allocationChart.data.datasets[0].data = chartData;
                allocationChart.data.datasets[0].backgroundColor = bgColors;
                allocationChart.update();

                const legend = document.getElementById('allocation-legend');
                legend.innerHTML = '';
                labels.forEach((label, idx) => {
                    const wt = totalValue > 0 ? (allocationMap[label] / totalValue) * 100 : 0;
                    legend.innerHTML += `
                        <div class="flex items-center justify-between text-xs py-1.5 border-b border-zinc-900">
                            <div class="flex items-center gap-2">
                                <span class="w-2.5 h-2.5 rounded-full" style="background-color: ${bgColors[idx]}"></span>
                                <span class="text-zinc-300 font-semibold">${label}</span>
                            </div>
                            <span class="text-zinc-500 font-bold">${wt.toFixed(1)}%</span>
                        </div>
                    `;
                });

            } catch (err) {
                console.error("Cockpit update error:", err);
            }
        }

        // ================= SYSTEM METRICS UTILITIES =================
        function showToast(title, msg, type = "success") {
            const toast = document.getElementById('status-toast');
            document.getElementById('toast-title').textContent = title;
            document.getElementById('toast-message').textContent = msg;
            
            const iconBox = document.getElementById('toast-icon-box');
            if (type === 'success') {
                toast.className = "fixed bottom-6 right-6 z-50 p-4 rounded-xl shadow-2xl flex items-center gap-3 max-w-sm transition-all duration-300 bg-zinc-900 border border-emerald-500/20";
                iconBox.className = "w-8 h-8 rounded-full flex items-center justify-center bg-emerald-500/10 text-emerald-400";
                iconBox.innerHTML = `<i data-lucide="check" class="w-4 h-4"></i>`;
            } else if (type === 'danger') {
                toast.className = "fixed bottom-6 right-6 z-50 p-4 rounded-xl shadow-2xl flex items-center gap-3 max-w-sm transition-all duration-300 bg-zinc-900 border border-rose-500/20";
                iconBox.className = "w-8 h-8 rounded-full flex items-center justify-center bg-rose-500/10 text-rose-400";
                iconBox.innerHTML = `<i data-lucide="shield-alert" class="w-4 h-4"></i>`;
            } else {
                toast.className = "fixed bottom-6 right-6 z-50 p-4 rounded-xl shadow-2xl flex items-center gap-3 max-w-sm transition-all duration-300 bg-zinc-900 border border-zinc-700/30";
                iconBox.className = "w-8 h-8 rounded-full flex items-center justify-center bg-zinc-800 text-zinc-400";
                iconBox.innerHTML = `<i data-lucide="info" class="w-4 h-4"></i>`;
            }

            toast.classList.remove('hidden');
            lucide.createIcons();
            setTimeout(() => { toast.classList.add('hidden'); }, 3500);
        }
    </script>
