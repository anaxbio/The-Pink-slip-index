                                        <th class="px-3 py-2">ETF</th>
                                        <th class="px-3 py-2 text-right">Qty</th>
                                        <th class="px-3 py-2 text-right">Avg Px</th>
                                        <th class="px-3 py-2 text-right">Live</th>
                                        <th class="px-3 py-2 text-center">Ctrl</th>
                                    </tr>
                                </thead>
