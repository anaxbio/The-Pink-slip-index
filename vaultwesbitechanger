<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MOMO DARK VAULT — Terminal</title>
    <!-- Core UI Dependencies -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');
        
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: #09090b; 
        }
        .font-mono-custom { 
            font-family: 'JetBrains Mono', monospace; 
        }
        .glass-panel { 
            background: rgba(18, 18, 24, 0.7); 
            backdrop-filter: blur(12px); 
            border: 1px solid rgba(63, 63, 70, 0.3); 
        }
        .glass-panel-input { 
            background: rgba(9, 9, 11, 0.8); 
            border: 1px solid rgba(63, 63, 70, 0.4); 
            transition: all 0.2s ease-in-out; 
        }
        .glass-panel-input:focus { 
            border-color: #10b981; 
            box-shadow: 0 0 10px rgba(16, 185, 129, 0.15); 
            outline: none; 
        }
        ::-webkit-scrollbar { 
            width: 6px; 
            height: 6px; 
        }
        ::-webkit-scrollbar-track { 
            background: #09090b; 
        }
        ::-webkit-scrollbar-thumb { 
            background: #27272a; 
            border-radius: 3px; 
        }
        ::-webkit-scrollbar-thumb:hover { 
            background: #3f3f46; 
        }
        @keyframes shake { 
            0%, 100% { transform: translateX(0); } 
            20%, 60% { transform: translateX(-6px); } 
            40%, 80% { transform: translateX(6px); } 
        }
        .animate-shake { 
            animation: shake 0.4s ease-in-out; 
        }
    </style>
</head>
<body class="text-zinc-100 min-h-screen flex flex-col antialiased">

    <!-- Security Overlay Gate -->
    <div id="security-gate" class="fixed inset-0 z-50 flex items-center justify-center bg-zinc-950/90 backdrop-blur-md transition-all duration-300">
        <div id="gate-container" class="w-full max-w-md p-8 rounded-2xl glass-panel border border-zinc-800 text-center mx-4">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 mb-6">
                <i data-lucide="shield-alert" class="w-8 h-8"></i>
            </div>
            <h1 class="text-2xl font-bold tracking-tight text-white mb-2">Terminal Verification</h1>
            <p class="text-zinc-400 text-sm mb-6">Accessing Momo Vault nodes requires environment clearance.</p>
            <form id="gate-form" class="space-y-4">
                <div>
                    <input type="password" id="gate-passkey" placeholder="Enter Vault Access Key..." class="w-full px-4 py-3 rounded-lg text-center font-mono-custom text-emerald-400 placeholder-zinc-600 glass-panel-input" required autocomplete="current-password">
                </div>
                <div id="gate-error" class="hidden text-rose-400 text-xs font-semibold py-1 rounded bg-rose-950/20 border border-rose-900/30">Access Denied: Invalid secure access token.</div>
                <button type="submit" id="gate-submit-btn" class="w-full py-3 bg-emerald-600 hover:bg-emerald-500 text-zinc-950 font-bold tracking-wider rounded-lg transition-all duration-200 shadow-lg shadow-emerald-950/40 flex items-center justify-center gap-2">
                    <i data-lucide="key-round" class="w-4 h-4"></i> AUTHENTICATE
                </button>
            </form>
        </div>
    </div>

    <div id="app-content" class="hidden flex-1 flex flex-col">
        <header class="border-b border-zinc-800 bg-zinc-950/50 backdrop-blur sticky top-0 z-40 px-6 py-4 flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-gradient-to-tr from-emerald-600 to-teal-500 flex items-center justify-center text-zinc-950 font-bold shadow-md shadow-emerald-950/20">M</div>
                <div>
                    <div class="flex items-center gap-2">
                        <h1 class="text-lg font-extrabold tracking-tight text-white font-mono-custom">MOMO_DARK_VAULT</h1>
                        <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 font-mono-custom">V3.0_METALS</span>
                    </div>
                    <p class="text-xs text-zinc-500">Autonomous Execution System • Multi-Desk Analytics</p>
                </div>
            </div>
            <div class="flex flex-wrap items-center gap-3 text-xs">
                <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-zinc-900 border border-zinc-800">
                    <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                    <span class="text-zinc-400">Database Bridge:</span>
                    <span class="text-zinc-200 font-semibold font-mono-custom">ONLINE</span>
                </div>
                <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-zinc-900 border border-zinc-800">
                    <i data-lucide="clock" class="w-3.5 h-3.5 text-zinc-400"></i>
                    <span class="text-zinc-400" id="header-time">00:00:00 IST</span>
                </div>
                <button onclick="terminateSession()" class="px-4 py-1.5 rounded-full bg-zinc-900 hover:bg-rose-950/20 border border-zinc-800 hover:border-rose-900/40 text-zinc-400 hover:text-rose-400 transition-all flex items-center gap-1.5">
                    <i data-lucide="lock" class="w-3.5 h-3.5"></i> Lock Vault
                </button>
            </div>
        </header>

        <!-- Dynamic Tabs Navigation -->
        <nav class="bg-zinc-950/80 border-b border-zinc-800/60 px-4 py-2 flex gap-1 overflow-x-auto sticky top-[73px] z-30 backdrop-blur-md scrollbar-hide">
            <button onclick="switchTab('family-cockpit')" id="tab-btn-family-cockpit" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-2 whitespace-nowrap text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900/50 border border-transparent"><i data-lucide="users" class="w-3.5 h-3.5"></i> Family Cockpit</button>
            <button onclick="switchTab('portfolio')" id="tab-btn-portfolio" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-2 whitespace-nowrap text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900/50 border border-transparent"><i data-lucide="briefcase" class="w-3.5 h-3.5"></i> Master Portfolio</button>
            <button onclick="switchTab('sgb-metals')" id="tab-btn-sgb-metals" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-2 whitespace-nowrap text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900/50 border border-transparent"><i data-lucide="gem" class="w-3.5 h-3.5"></i> SGB & Metals</button>
            <button onclick="switchTab('depth')" id="tab-btn-depth" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-2 whitespace-nowrap text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900/50 border border-transparent"><i data-lucide="bar-chart-2" class="w-3.5 h-3.5"></i> Depth Map</button>
            <button onclick="switchTab('top2')" id="tab-btn-top2" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-2 whitespace-nowrap text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900/50 border border-transparent"><i data-lucide="trending-up" class="w-3.5 h-3.5"></i> Top 2 Allocator</button>
            <button onclick="switchTab('etf')" id="tab-btn-etf" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-2 whitespace-nowrap text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900/50 border border-transparent"><i data-lucide="layers" class="w-3.5 h-3.5"></i> ETF Aligner</button>
            <button onclick="switchTab('intraday')" id="tab-btn-intraday" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-2 whitespace-nowrap text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900/50 border border-transparent"><i data-lucide="crosshair" class="w-3.5 h-3.5"></i> Intraday Hunter</button>
            <button onclick="switchTab('swing')" id="tab-btn-swing" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-2 whitespace-nowrap text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900/50 border border-transparent"><i data-lucide="activity" class="w-3.5 h-3.5"></i> Swing Engine</button>
            <button onclick="switchTab('silent')" id="tab-btn-silent" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-2 whitespace-nowrap text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900/50 border border-transparent"><i data-lucide="eye-off" class="w-3.5 h-3.5"></i> Silent Signal</button>
        </nav>

        <main class="flex-1 p-6 space-y-6 max-w-[1600px] w-full mx-auto">

            <!-- TAB 1: Family Cockpit -->
            <section id="tab-family-cockpit" class="space-y-6">
                <div class="flex items-center justify-between">
                    <div>
                        <h2 class="text-xl font-bold tracking-tight text-white flex items-center gap-2">
                            <i data-lucide="users" class="text-emerald-500 w-5 h-5"></i> Family Cockpit
                        </h2>
                        <p class="text-xs text-zinc-500 mt-1">Consolidated Family Office Wealth, Owner Filters, and Asset Allocation.</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-zinc-500 font-bold uppercase tracking-wider">Filter Entity:</span>
