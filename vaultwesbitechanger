    <script>
        const TABS = ['family-cockpit', 'portfolio', 'sgb-metals', 'depth', 'top2', 'etf', 'intraday', 'swing', 'silent'];
        let currentActiveTab = 'family-cockpit';
        let refreshTimer = null;
        let allocationChart = null;

        // Live prices map
        let nse_mkt = {};
        let mcx_mkt = {};
        let ledgerData = [];
        
        // Manual Price Override Stress State
        let override_active = false;
        let override_prices = {};

        // SGB Horizon Math Parameters matching tabs_metals (12).py
        const static_horizons = {
            "SGBOCT26": { months: 4, rolls: 0 },
            "SGBNOV26": { months: 5, rolls: 1 },
            "SGBDEC26": { months: 6, rolls: 2 },
            "SGBJAN27": { months: 7, rolls: 3 },
            "SGBFEB27": { months: 8, rolls: 4 }
        };

        window.onload = function() {
            lucide.createIcons();
            startClock();
            document.getElementById('gate-form').addEventListener('submit', handleSecuritySubmit);
            inspectVaultToken();
        };

        function startClock() {
            setInterval(() => {
                const now = new Date();
                const ist = new Date(now.getTime() + (now.getTimezoneOffset() * 60000) + (3600000 * 5.5));
                document.getElementById('header-time').textContent = ist.toTimeString().split(' ')[0] + " IST";
            }, 1000);
        }

        // ================= SECURITY GATE =================
        function inspectVaultToken() {
            const activeToken = sessionStorage.getItem('X-Vault-Token');
            if (activeToken) {
                hideLockOverlay();
                initializeDashboard();
            } else {
                showLockOverlay();
            }
        }

        function showLockOverlay(msg = '') {
            document.getElementById('security-gate').classList.remove('hidden');
            document.getElementById('app-content').classList.add('hidden');
            const err = document.getElementById('gate-error');
            if (msg) { err.textContent = msg; err.classList.remove('hidden'); }
        }

        function hideLockOverlay() {
            document.getElementById('security-gate').classList.add('hidden');
            document.getElementById('app-content').classList.remove('hidden');
        }

        async function handleSecuritySubmit(e) {
            e.preventDefault();
            const passkey = document.getElementById('gate-passkey').value.trim();
            if (!passkey) return;

            const btn = document.getElementById('gate-submit-btn');
            btn.disabled = true;
            btn.innerHTML = `<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> VERIFYING...`;
            lucide.createIcons();

            try {
                const response = await fetch('/api/vault/market_data', {
                    method: 'GET',
                    headers: { 'X-Vault-Token': passkey }
                });

                if (response.status === 200) {
                    sessionStorage.setItem('X-Vault-Token', passkey);
                    hideLockOverlay();
                    showToast("Access Approved", "Vault keys synced.", "success");
                    initializeDashboard();
                } else {
                    throw new Error("Unauthorized");
                }
            } catch (err) {
                document.getElementById('gate-error').classList.remove('hidden');
                document.getElementById('gate-container').classList.add('animate-shake');
                setTimeout(() => document.getElementById('gate-container').classList.remove('animate-shake'), 400);
            } finally {
                btn.disabled = false;
                btn.innerHTML = `<i data-lucide="key-round" class="w-4 h-4"></i> AUTHENTICATE`;
                lucide.createIcons();
            }
        }

        function terminateSession() {
            sessionStorage.removeItem('X-Vault-Token');
            showLockOverlay("Session locked.");
        }

        async function secureApiRequest(endpoint, options = {}) {
            const token = sessionStorage.getItem('X-Vault-Token');
            if (!token) throw new Error("No secure token stored.");
            options.headers = { ...options.headers, 'X-Vault-Token': token };
            const res = await fetch(endpoint, options);
            if (res.status === 401) { terminateSession(); throw new Error("Unauthorized."); }
            if (!res.ok) throw new Error("Database transaction failed.");
            return await res.json();
        }

        // ================= TAB NAVIGATION =================
        function switchTab(tabId) {
            currentActiveTab = tabId;
            TABS.forEach(t => {
                document.getElementById(`tab-${t}`).classList.add('hidden');
                const btn = document.getElementById(`tab-btn-${t}`);
                if (btn) {
                    btn.className = "px-4 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-2 whitespace-nowrap text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900/50 border border-transparent";
                }
            });

            document.getElementById(`tab-${tabId}`).classList.remove('hidden');
            const activeBtn = document.getElementById(`tab-btn-${tabId}`);
            if (activeBtn) {
                activeBtn.className = "px-4 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-2 whitespace-nowrap text-emerald-400 bg-emerald-500/5 border border-emerald-500/10";
            }

            if (tabId === 'family-cockpit') updateCockpitView();
            if (tabId === 'portfolio') loadPortfolioLedger();
            if (tabId === 'sgb-metals') triggerMetalsRecalculation();
            if (tabId === 'depth') renderDepthMap();
        }

        function initializeDashboard() {
            initChart();
            startPollingCycle();
            switchTab('family-cockpit');
        }

        function startPollingCycle() {
            if (refreshTimer) clearInterval(refreshTimer);
            
            refreshTimer = setInterval(async () => {
                await fetchLiveMarketData();
                if (currentActiveTab === 'portfolio') calculateLedgerMetrics();
                if (currentActiveTab === 'sgb-metals') triggerMetalsRecalculation();
                if (currentActiveTab === 'depth') renderDepthMap();
            }, 3000);

            fetchLiveMarketData();
        }

        // ================= MATHEMATICAL LEDGER INGESTION & DATA SYNC =================
        async function fetchLiveMarketData() {
            try {
                const data = await secureApiRequest('/api/vault/market_data');
                
                for (let key in data) {
                    const ltp = parseFloat(data[key].ltp || 0.0);
                    const bid = parseFloat(data[key].bid || ltp);
                    const ask = parseFloat(data[key].ask || ltp);
                    const entry = {
                        ltp: ltp,
                        bids: [[bid, data[key].volume || 1]],
                        asks: [[ask, data[key].volume || 1]]
                    };

                    const cleanKey = key.replace('FUT', '').trim();
                    if (key.includes('GOLDPETAL') || key.includes('SILVERMIC')) {
                        mcx_mkt[key] = entry;
                        mcx_mkt[cleanKey] = entry;
                    } else {
                        nse_mkt[key] = entry;
                        nse_mkt[cleanKey] = entry;
                    }
                }
            } catch (err) {
                console.error("Market tick pull interrupted:", err);
            }
        }

        // ================= STRESS TEST OVERRIDES =================
        function toggleManualOverride() {
            override_active = document.getElementById('override-active-toggle').checked;
            const panel = document.getElementById('stress-override-panel');
            
            if (override_active) {
                panel.classList.remove('hidden');
                generateOverrideInputs();
            } else {
                panel.classList.add('hidden');
                calculateLedgerMetrics();
                triggerMetalsRecalculation();
            }
        }

        function generateOverrideInputs() {
            const container = document.getElementById('override-inputs-container');
            container.innerHTML = '';

            const longSyms = new Set();
            const shortSyms = new Set();

            ledgerData.forEach(item => {
                if (item.asset_class === 'SGB' || item.asset_class === 'Silver ETF') {
                    longSyms.add(item.asset_name);
                } else if (item.asset_class.includes('MCX') || item.asset_class.includes('Short')) {
                    shortSyms.add(item.asset_name);
                }
            });

            // Standard tickers
            ["SGBOCT26", "SGBNOV26", "SGBDEC26", "SGBJAN27", "SGBFEB27"].forEach(s => longSyms.add(s));
            ["GOLDPETAL30OCT26FUT", "SILVERMIC30OCT26FUT"].forEach(s => shortSyms.add(s));

            longSyms.forEach(sym => {
                const livePx = getEffectivePrice(sym, false);
                if (!override_prices[sym]) override_prices[sym] = livePx;

                container.innerHTML += `
                    <div class="bg-zinc-900/40 p-3 rounded-lg border border-zinc-850 flex items-center justify-between text-xs font-mono-custom">
                        <span class="text-zinc-400 font-bold">${sym} (Long)</span>
                        <input type="number" value="${override_prices[sym]}" oninput="updateOverrideValue('${sym}', this.value)" class="w-24 px-2 py-1 rounded bg-zinc-950 border border-zinc-800 text-right text-emerald-400 font-bold">
                    </div>
                `;
            });

            shortSyms.forEach(sym => {
                const livePx = getEffectivePrice(sym, true);
                if (!override_prices[sym]) override_prices[sym] = livePx;

                container.innerHTML += `
                    <div class="bg-zinc-900/40 p-3 rounded-lg border border-zinc-850 flex items-center justify-between text-xs font-mono-custom">
                        <span class="text-zinc-400 font-bold text-rose-400">${sym} (Short)</span>
                        <input type="number" value="${override_prices[sym]}" oninput="updateOverrideValue('${sym}', this.value)" class="w-28 px-2 py-1 rounded bg-zinc-950 border border-zinc-800 text-right text-rose-400 font-bold">
                    </div>
                `;
            });
        }

        function updateOverrideValue(sym, val) {
            override_prices[sym] = parseFloat(val) || 0.0;
            calculateLedgerMetrics();
            triggerMetalsRecalculation();
        }

        function getEffectivePrice(sym, isMcx = false) {
            const cleanSym = sym.replace('FUT', '').trim();
            if (override_active && override_prices[sym] !== undefined) return override_prices[sym];
            if (override_active && override_prices[cleanSym] !== undefined) return override_prices[cleanSym];

            const lookup = isMcx ? mcx_mkt : nse_mkt;
            const tick = lookup[sym] || lookup[cleanSym];
            if (tick && tick.ltp > 0) return tick.ltp;

            // ZERO CHEATING FALLBACKS: If the live relay is dead, return exactly 0.0
            return 0.0;
        }

        // ================= PORTFOLIO MATH & CALCULATION ENGINE =================
        async function loadPortfolioLedger() {
            try {
                const analytics = await secureApiRequest('/api/vault/metals_analytics');
                ledgerData = analytics.ledger_items || [];
                
                calculateLedgerMetrics();
                buildEditableTables();
                populateExitDeskOptions();
            } catch (err) {
                console.error("Ledger sync failure:", err);
            }
        }

        function calculateLedgerMetrics() {
            let goldPnL = 0.0;
            let silverPnL = 0.0;
            const accountLedgerMap = {};

            const hasBees = ledgerData.some(item => item.asset_name.toUpperCase().includes("BEES") && item.asset_class.toUpperCase().includes("SILVER"));
            const hasCase = ledgerData.some(item => item.asset_name.toUpperCase().includes("CASE") && item.asset_class.toUpperCase().includes("SILVER"));

            ledgerData.forEach(item => {
                const sym = item.asset_name;
                const acc = item.account || "UNASSIGNED";
                const qty = parseFloat(item.qty || 0.0);
                const avgPx = parseFloat(item.avg_price || 0.0);
                const assetClass = item.asset_class || "";

                if (qty <= 0) return;

                const isMcx = assetClass.toUpperCase().includes("MCX") || sym.includes("FUT");
                const ltp = getEffectivePrice(sym, isMcx);

                if (!accountLedgerMap[acc]) {
                    accountLedgerMap[acc] = { net_pnl: 0.0, short_mtm: 0.0, req_buffer: 0.0, has_shorts: false };
                }

                // Long Holdings Calculation
                if (!isMcx) {
                    const pnl = (ltp - avgPx) * qty;
                    if (assetClass === 'SGB' || assetClass.toUpperCase().includes("GOLD")) {
                        goldPnL += pnl;
                    } else {
                        silverPnL += pnl;
                    }
                    accountLedgerMap[acc].net_pnl += pnl;
                } 
                // Short Liabilities Calculation (with strict contract scaling multipliers)
                else {
                    let pnl = 0.0;
                    if (sym.toUpperCase().includes("GOLD") || sym.toUpperCase().includes("PETAL")) {
                        pnl = (avgPx - ltp) * qty;
                        goldPnL += pnl;
                        accountLedgerMap[acc].net_pnl += pnl;
                    } else if (sym.toUpperCase().includes("SILVER") || sym.toUpperCase().includes("MIC")) {
                        // Apply precise BEES/CASE multiplier scale conditions
                        if (hasBees) {
                            pnl = ((avgPx / 1000.0) - (ltp / 1000.0)) * (qty * 1000.0);
                        } else if (hasCase) {
                            pnl = ((avgPx / 10000.0) - (ltp / 10000.0)) * (qty * 10000.0);
                        } else {
                            pnl = (avgPx - ltp) * qty;
                        }
                        silverPnL += pnl;
                        accountLedgerMap[acc].net_pnl += pnl;
                    }

                    // Track Cash Margin Shield Liability
                    const notional = ltp * qty;
                    const buffer = notional * 0.10; // Strict 10% Cash Cushion requirement

                    accountLedgerMap[acc].short_mtm += pnl;
                    accountLedgerMap[acc].req_buffer += buffer;
                    accountLedgerMap[acc].has_shorts = true;
                }
            });

            // Update Global Metrics KPI displays
            const totalNet = goldPnL + silverPnL;
            document.getElementById('kpi-gold-pnl').textContent = `₹ ${goldPnL.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
            document.getElementById('kpi-silver-pnl').textContent = `₹ ${silverPnL.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
            
            const totalEl = document.getElementById('kpi-total-net-pnl');
            totalEl.textContent = `₹ ${totalNet.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
            totalEl.className = totalNet >= 0 ? "text-2xl font-extrabold font-mono-custom text-emerald-400 mt-1" : "text-2xl font-extrabold font-mono-custom text-rose-500 mt-1";

            // Render Individual Account Ledger Margin Cards
            renderMarginCards(accountLedgerMap);
        }

