        async function commitRowSave(id) {
            const dataToSave = editedFields[id];
            if (!dataToSave) {
                showToast("Skipped", "No fields were modified.", "info");
                return;
            }

            try {
                const payload = {
                    account: dataToSave.account,
                    owner: dataToSave.account.includes('SID') ? 'SID' : dataToSave.account.includes('HUF') ? 'HUF' : dataToSave.account.includes('ANU') ? 'ANU' : 'AAI',
                    asset_name: dataToSave.asset_name,
                    isin: dataToSave.isin || "",
                    asset_class: dataToSave.asset_class,
                    qty: parseFloat(dataToSave.qty),
                    avg_price: parseFloat(dataToSave.avg_price)
                };

                if (typeof id === 'number') payload.id = id;

                await secureApiRequest('/api/vault/upsert_ledger_item', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                delete editedFields[id];
                showToast("Ledger Synchronized", "Position modifications updated in database.", "success");
                loadPortfolioLedger();
            } catch (err) {
                showToast("Update Failed", err.message, "danger");
            }
        }

