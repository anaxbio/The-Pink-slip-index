        async function executeServerCalculationEngine(current_inputs_payload) {
            const isPanicStateActive = current_inputs_payload.panic_toggle;
            const inflation_pct = current_inputs_payload.inflation_slider;

            try {
                const server_response = await fetch('https://api.pinkslipindex.com/v2/vault_calc', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${currentToken}`
                    },
                    body: JSON.stringify(current_inputs_payload)
                });

                if (server_response.status === 401 || server_response.status === 403) {
                    alert("Session expired. Please re-authenticate your premium gateway profile account.");
                    window.location.href = 'index.html';
                    return;
                }

                if (server_response.ok) {
                    const s_data = await server_response.json();
                    
                    document.getElementById('lbl_total_monthly_burn').innerText = fmt(s_data.raw_monthly_burn);
                    document.getElementById('lbl_total_annual_spikes').innerText = fmt(s_data.raw_annual_spikes);
                    
                    const total_baseline_wealth = s_data.equity_base + s_data.debt_base + s_data.cash_base + s_data.metals_base + s_data.real_estate_base;
                    document.getElementById('lbl_total_assets').innerText = fmt(total_baseline_wealth);
                    document.getElementById('lbl_total_liabilities').innerText = fmt(s_data.total_debts);

                    document.getElementById('re_liquidation').max = s_data.real_estate_base;

                    const rentWarning = document.getElementById('rent_warning');
                    if (current_inputs_payload.re_liquidation > 0) {
                        if (rentWarning.style.display === 'none') {
                            document.getElementById('simulated_monthly_rent').value = Math.round((s_data.real_estate_base * 0.03) / 12);
                        }
                        rentWarning.style.display = 'flex';
                    } else {
                        rentWarning.style.display = 'none';
                        document.getElementById('simulated_monthly_rent').value = 0;
                    }

                    const active_inflow = isPanicStateActive ? 0 : current_inputs_payload.total_active_inflows;
                    const total_inflow = active_inflow + current_inputs_payload.total_passive_inflows;
                    const base_monthly_outflow = s_data.raw_monthly_burn + (s_data.raw_monthly_burn * (current_inputs_payload.expense_shock / 100)) + (s_data.raw_annual_spikes / 12);
                    const net_monthly_cashflow = total_inflow - (base_monthly_outflow * (1 + (inflation_pct / 100)));

                    const cashflowBox = document.getElementById('cashflow_box');
                    const cashflowLabel = document.getElementById('cashflow_label');
                    const cashflowVal = document.getElementById('lbl_net_cashflow');
                    if (net_monthly_cashflow >= 0) {
                        cashflowBox.className = "sidebar-cashflow-badge"; cashflowLabel.innerText = "CASH FLOW SURPLUS"; cashflowVal.innerText = "+₹" + fmt(net_monthly_cashflow);
                    } else {
                        cashflowBox.className = "sidebar-cashflow-badge deficit-flash"; cashflowLabel.innerText = "CASH FLOW DEFICIT"; cashflowVal.innerText = "-₹" + fmt(Math.abs(net_monthly_cashflow));
                    }

                    document.getElementById('tax_total_val').innerText = fmt(s_data.total_friction);
                    document.getElementById('tax_equity').innerText = '₹' + fmt(s_data.total_eq_loss);
                    document.getElementById('tax_re').innerText = '₹' + fmt(s_data.re_loss);
                    document.getElementById('tax_other').innerText = '₹' + fmt(s_data.other_loss);
                    document.getElementById('lbl_gut_punch_friction').innerText = '₹' + fmt(s_data.total_friction);

                    document.getElementById('val_months').innerText = fmt(s_data.completed_months) + " Months"; 
                    document.getElementById('val_years').innerText = `${Math.round((s_data.completed_months/12) * 10) / 10} Years Runway Capacity`; 

                    const terminalAgeTarget = 85;
                    let yearsNeededToCover = Math.max(1, terminalAgeTarget - current_inputs_payload.current_age);
                    let calculatedYearsRunway = s_data.completed_months / 12;
                    
                    let rawPsiScore = 0;
                    if (total_baseline_wealth > 0) {
                        rawPsiScore = (calculatedYearsRunway / yearsNeededToCover) * 100;
                    }
                    let finalPsiScore = Math.min(100, Math.max(0, rawPsiScore));

                    const progressFill = document.getElementById('bar_psi_fill');
                    if (progressFill) progressFill.style.width = finalPsiScore + '%';

                    const scoreReadoutLabel = document.getElementById('lbl_green_score');
                    if (scoreReadoutLabel) scoreReadoutLabel.innerText = finalPsiScore.toFixed(1);

                    const targetRotationDegrees = -120 + (finalPsiScore * 2.4);
                    const needleSvgObject = document.getElementById('gauge_needle_pin');
                    if (needleSvgObject) needleSvgObject.style.transform = `rotate(${targetRotationDegrees}deg)`;

                    const totalArcStrokeLength = 502; 
                    const currentFillStrokeLength = (finalPsiScore / 100) * totalArcStrokeLength;
                    const greenPathSegment = document.getElementById('gauge_green_fill');
                    const redPathSegment = document.getElementById('gauge_red_fill');

                    if (isPanicStateActive) {
                        if (greenPathSegment) greenPathSegment.style.display = 'none';
                        if (redPathSegment) {
                            redPathSegment.style.display = 'block';
                            redPathSegment.style.strokeDasharray = `${currentFillStrokeLength} ${totalArcStrokeLength}`;
                        }
                    } else {
                        if (redPathSegment) redPathSegment.style.display = 'none';
                        if (greenPathSegment) {
                            greenPathSegment.style.display = 'block';
                            greenPathSegment.style.strokeDasharray = `${currentFillStrokeLength} ${totalArcStrokeLength}`;
                        }
                    }

                    const banner = document.getElementById('banner');
                    if (banner) {
                        banner.style.display = 'block';
                        if (s_data.completed_months < 6) {
                            banner.style.backgroundColor = "#FFF5F5"; banner.style.borderColor = "var(--accent-danger)";
                            document.getElementById('status_text').innerText = "🚨 LIQUIDITY LIQUIDATION OVERRUN TRIGGERED";
                            document.getElementById('hero_text').innerText = `Simulation Breach Point Discovered at Month ${Math.round(s_data.completed_months)}`;
                        } else {
                            banner.style.backgroundColor = isPanicStateActive ? "#1A0B0B" : "#ECFDF5"; banner.style.borderColor = isPanicStateActive ? "#DC2626" : "var(--accent-safe)";
                            document.getElementById('status_text').innerText = isPanicStateActive ? "🚨 PANIC INTERACTIVE EXECUTION ACTIVE" : "🟢 RUNWAY CAPACITY SECURE";
                            document.getElementById('hero_text').innerText = `Your Networth Shields You Until Age ${Math.round(current_inputs_payload.current_age + (s_data.completed_months / 12))}`;
                        }
                    }

                    const vault_table = document.getElementById('vault_table');
                    if (vault_table) {
                        const totalBaselineDenom = total_baseline_wealth || 1;
                        const baselineEqPct = Math.round((s_data.equity_base / totalBaselineDenom) * 100);
                        const baselineFI = Math.round((s_data.debt_base / totalBaselineDenom) * 100);
                        const baselineCash = Math.round((s_data.cash_base / totalBaselineDenom) * 100);
                        const baselineRE = Math.round((s_data.real_estate_base / totalBaselineDenom) * 100);
                        const baselineMetals = Math.round((s_data.metals_base / totalBaselineDenom) * 100);

                        const final_equity_total = s_data.equity_base * (1 + (current_inputs_payload.equity_shift / 100));
                        const final_metals_total = s_data.metals_base * (1 + (current_inputs_payload.metals_shift / 100));
                        
                        const survivalDenom = (final_equity_total + s_data.debt_base + s_data.cash_base + (s_data.real_estate_base - current_inputs_payload.re_liquidation) + final_metals_total) || 1;
                        
                        const survEqPct = Math.round((final_equity_total / survivalDenom) * 100);
                        const survFIPct = Math.round((s_data.debt_base / survivalDenom) * 100);
                        const survCashPct = Math.round((s_data.cash_base / survivalDenom) * 100);
                        const survREPct = Math.round(((s_data.real_estate_base - current_inputs_payload.re_liquidation) / survivalDenom) * 100);
                        const survMetalsPct = Math.round((final_metals_total / survivalDenom) * 100);

                        if (isPanicStateActive) {
                            vault_table.innerHTML = `
                                <tr><td>Equity - MF+Direct</td><td>₹${fmt(s_data.equity_base)} (${baselineEqPct}%)</td><td><span style="color:var(--accent-danger)">-₹${fmt(s_data.total_eq_loss)}</span></td><td>₹${fmt(s_data.final_equity - s_data.total_eq_loss)} (${survEqPct}%)</td></tr>
                                <tr><td>FD+Debt MF</td><td>₹${fmt(s_data.debt_base)} (${baselineFI}%)</td><td><span style="color:var(--accent-danger)">-₹${fmt(s_data.other_loss)}</span></td><td>₹${fmt(s_data.debt_base - s_data.other_loss)} (${survFIPct}%)</td></tr>
                                <tr><td>Savings / Cash Balance</td><td>₹${fmt(s_data.cash_base)} (${baselineCash}%)</td><td><span>0%</span></td><td>₹${fmt(s_data.cash_base)} (${survCashPct}%)</td></tr>
                                <tr><td>Real Estate Class</td><td>₹${fmt(s_data.real_estate_base)} (${baselineRE}%)</td><td><span style="color:var(--accent-danger)">-₹${fmt(s_data.re_loss + s_data.home_loan_base)}</span></td><td>₹${fmt(s_data.effective_re_released)} (${survREPct}%)</td></tr>
                                <tr><td>Commodities & Gold</td><td>₹${fmt(s_data.metals_base)} (${baselineMetals}%)</td><td><span>0%</span></td><td>₹${fmt(s_data.metals_base)} (${survMetalsPct}%)</td></tr>
                            `;
                        } else {
                            vault_table.innerHTML = `
                                <tr><td>Equity - MF+Direct</td><td>₹${fmt(s_data.equity_base)} (${baselineEqPct}%)</td><td><span style="color: ${final_equity_total - s_data.equity_base >= 0 ? 'var(--accent-safe)' : 'var(--accent-danger)'}">${current_inputs_payload.equity_shift}%</span></td><td>₹${fmt(final_equity_total)} (${survEqPct}%)</td></tr>
                                <tr><td>FD+Debt MF</td><td>₹${fmt(s_data.debt_base)} (${baselineFI}%)</td><td><span>0%</span></td><td>₹${fmt(s_data.debt_base)} (${survFIPct}%)</td></tr>
                                <tr><td>Savings / Cash Balance</td><td>₹${fmt(s_data.cash_base)} (${baselineCash}%)</td><td><span>0%</span></td><td>₹${fmt(s_data.cash_base)} (${survCashPct}%)</td></tr>
                                <tr><td>Real Estate Class</td><td>₹${fmt(s_data.real_estate_base)} (${baselineRE}%)</td><td><span style="color:var(--accent-danger)">-${fmt(current_inputs_payload.re_liquidation)}</span></td><td>₹${fmt(s_data.real_estate_base - current_inputs_payload.re_liquidation)} (${survREPct}%)</td></tr>
                                <tr><td>Commodities & Gold</td><td>₹${fmt(s_data.metals_base)} (${baselineMetals}%)</td><td><span style="color: ${final_metals_total - s_data.metals_base >= 0 ? 'var(--accent-safe)' : 'var(--accent-danger)'}">${current_inputs_payload.metals_shift}%</span></td><td>₹${fmt(final_metals_total)} (${survMetalsPct}%)</td></tr>
                            `;
                        }
                    }

                    const denominator = total_baseline_wealth || 1;
                    const eq_weight = s_data.equity_base / denominator;
                    const fd_weight = s_data.debt_base / denominator;
                    const cash_weight = s_data.cash_base / denominator;
                    const re_weight = s_data.real_estate_base / denominator;
                    const metal_weight = s_data.metals_base / denominator;

                    const eq_3 = 14.5, eq_5 = 12.8, eq_10 = 11.5;
                    const fd_3 = 7.1,  fd_5 = 6.8,  fd_10 = 7.0;
                    const cs_3 = 3.5,  cs_5 = 3.5,  cs_10 = 3.5;
                    const re_3 = 6.0,  re_5 = 5.5,  re_10 = 5.8;
                    const met_3 = 8.5, met_5 = 9.0, met_10 = 8.2;

                    const blended_3 = (eq_weight * eq_3) + (fd_weight * fd_3) + (cash_weight * cs_3) + (re_weight * re_3) + (metal_weight * met_3);
                    const blended_5 = (eq_weight * eq_5) + (fd_weight * fd_5) + (cash_weight * cs_5) + (re_weight * re_3) + (metal_weight * met_5);
                    const blended_10 = (eq_weight * eq_10) + (fd_weight * fd_10) + (cash_weight * cs_10) + (re_weight * re_3) + (metal_weight * met_10);

                    document.getElementById('v_3yr').innerText = "+" + blended_3.toFixed(1) + "% CAGR";
                    document.getElementById('v_5yr').innerText = "+" + blended_5.toFixed(1) + "% CAGR";
                    document.getElementById('v_10yr').innerText = "+" + blended_10.toFixed(1) + "% CAGR";

                    let runtime_burn_adjusted = s_data.raw_monthly_burn * (1 + (current_inputs_payload.expense_shock / 100));
                    let targetFICorpus = runtime_burn_adjusted * 12 * 30; 
                    let remainingDistanceGap = targetFICorpus - (total_baseline_wealth - s_data.total_debts);

                    document.getElementById('lbl_nav_route').innerText = '₹' + fmt(targetFICorpus);
                    const remainLabel = document.getElementById('lbl_nav_remain');
                    if (remainingDistanceGap > 0) {
                        remainLabel.innerText = '-₹' + fmt(remainingDistanceGap);
                        remainLabel.style.color = '#EF4444';
                    } else {
                        remainLabel.innerText = 'ARRIVED';
                        remainLabel.style.color = '#10B981';
                    }

                    document.getElementById('lbl_legend_surviving').innerText = '₹' + fmt(s_data.surviving_pool || 0);
                    document.getElementById('lbl_legend_wiped').innerText = '₹' + fmt(s_data.total_friction || 0);
                    document.getElementById('lbl_legend_liquid').innerText = '₹' + fmt((s_data.final_equity || 0) + (s_data.debt_base || 0) + (s_data.cash_base || 0));
                    document.getElementById('lbl_legend_hard').innerText = '₹' + fmt(s_data.metals_base || 0);
                    document.getElementById('lbl_legend_trapped').innerText = '₹' + fmt(s_data.real_estate_base || 0);

                    const survivingPct = Math.min(100, Math.max(0, ((s_data.surviving_pool || 0) / (total_baseline_wealth || 1)) * 100));
                    const wipedPct = 100 - survivingPct;

                    document.getElementById('bar_surviving').style.width = survivingPct + '%';
                    document.getElementById('bar_wiped').style.width = wipedPct + '%';
                }
            } catch (e) {
                console.error("Transmission exception encountered.", e);
            } finally {
                stopScoreboardAnimations();
            }
        }

        const inputsArr = [
            'inc_salary', 'inc_business', 'inc_consulting', 'inc_rental', 'inflation_slider', 'current_age',
            'param_eq_yield', 'param_fi_yield', 'param_metal_yield', 'param_tax_drag',
            'ast_demat', 'ast_mf_eq', 'ast_pe', 'ast_fd', 'ast_mf_debt', 'ast_bonds', 'ast_nps', 'ast_cash', 'ast_gold_digi', 'ast_re_primary', 'ast_re_second', 'ast_gold_phys',
            'lia_home_primary', 'lia_home_second', 'lia_auto', 'lia_personal', 'lia_education', 'lia_cc', 'lia_other', 
            'equity_shift', 'metals_shift', 'expense_shock', 're_liquidation', 'simulated_monthly_rent',
            'exp_rent_emi', 'exp_other_emi', 'exp_food_kirana', 'exp_utilities', 'exp_domestic_help', 'exp_fuel_commute', 'exp_dining_out', 'exp_other_1', 'exp_other_2', 'exp_misc_buffer',
            'ann_insurance', 'ann_school_fees', 'ann_festivals', 'ann_maintenance', 'ann_vacations', 'stcg_equity', 're_taxable_gain', 're_distress_pct'
        ];
        inputsArr.forEach(id => { const el = document.getElementById(id); if (el) el.addEventListener('input', calculate); });
    </script>
</body>
</html>
