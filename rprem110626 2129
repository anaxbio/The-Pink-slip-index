# --- LOCAL WHITELIST HELPERS (No Database Engine Dependency) ---
def add_email_to_whitelist(email: str):
    email_clean = email.strip().lower()
    existing = get_whitelisted_emails()
    if email_clean not in existing:
        with open(WHITELIST_FILE, "a") as f:
            f.write(f"{email_clean}\n")

def get_whitelisted_emails():
    if not os.path.exists(WHITELIST_FILE):
        return set()
    with open(WHITELIST_FILE, "r") as f:
        return set(line.strip().lower() for line in f if line.strip())


# --- STANDALONE DECOUPLED PAYMENT WEBHOOK ENDPOINT ---
@router.post("/api/v2/payment-callback")
async def receive_standalone_payment_webhook(request: Request):
    """
    Listens exclusively for confirmation data from your detached payment gateway.
    Extracts the customer email and writes it directly to your local whitelist ledger.
    """
    try:
        payload = await request.json()
        
        # Razorpay Standard webhook structural parsing format
        if "payload" in payload and "payment" in payload["payload"]:
            payment_entity = payload["payload"]["payment"]["entity"]
            customer_email = payment_entity.get("email")
            if customer_email:
                add_email_to_whitelist(customer_email)
                return {"status": "success", "message": "Email whitelisted successfully"}
                
        raise HTTPException(status_code=400, detail="Invalid payment payload structure")
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Webhook parsing exception: {str(e)}")


# --- FREE GOOGLE OAUTH IDENTITY HANDSHAKE ENDPOINT ---
@router.post("/auth/google-callback")
async def google_oauth_identity_callback(payload: dict):
    """
    Receives Google's secure cryptographically signed Identity Token from the client browser.
    Verifies token validity against Google's public APIs and cross-checks your whitelist.
    """
    google_token = payload.get("id_token")
    if not google_token:
        raise HTTPException(status_code=400, detail="Missing Google ID token payload.")
        
    try:
        # Secure server-to-server confirmation call verifying Google's cryptographic signature
        res = requests.get(f"https://oauth2.googleapis.com/tokeninfo?id_token={google_token}")
        if res.status_code != 200:
            raise HTTPException(status_code=401, detail="Invalid cryptographic token token from Google.")
            
        google_profile = res.json()
        verified_email = google_profile.get("email", "").strip().lower()
        
        if not verified_email:
            raise HTTPException(status_code=400, detail="Unable to retrieve verified email from token profiles.")

        # 🛡️ SYSTEM GATEKEEPER CHECK WITH MASTER DEVELOPER ESCAPE HATCH
        is_developer = (verified_email == DEVELOPER_MASTER_EMAIL.lower())
        is_paying_client = (verified_email in get_whitelisted_emails())

        if not (is_developer or is_paying_client):
            raise HTTPException(status_code=403, detail="Access denied. Email address is not whitelisted.")

        # Stamp a local signed JWT application session key for the validated profile
        session_expiration = int(time.time()) + (3600 * 24 * 7)  # Active for 7 days
        app_token_payload = {
            "email": verified_email,
            "exp": session_expiration,
            "role": "premium" if not is_developer else "developer"
        }
        
        signed_app_token = jwt.encode(app_token_payload, JWT_SECRET, algorithm=JWT_ALGORITHM)
        return {"status": "authenticated", "access_token": signed_app_token}

    except Exception as e:
        if isinstance(e, HTTPException): raise e
        raise HTTPException(status_code=500, detail=f"Authentication loop failure: {str(e)}")


# --- STRICT PREMIUM PRODUCTION SECURITY GATEWAY ---
async def verify_premium_token(authorization: str = Header(None)):
    """
    Cryptographically verifies the native, short-term user session token header.
    Secures the monetization boundary from unauthenticated public traffic.
    """
    if not authorization:
        raise HTTPException(status_code=401, detail="Missing authorization header.")
    
    try:
        token_type, token = authorization.split(" ")
        if token_type.lower() != "bearer":
            raise HTTPException(status_code=401, detail="Invalid token type prefix.")
        
        payload = jwt.decode(token, JWT_SECRET, algorithms=[JWT_ALGORITHM])
        return payload
    except (ValueError, jwt.ExpiredSignatureError, jwt.InvalidTokenError):
        raise HTTPException(status_code=401, detail="Access token is invalid or expired.")


# --- PRODUCTION CALCULATION LOOP ENGINE (STRICTLY UNTOUCHED) ---
@router.post("/v2/vault_calc")
async def process_flat_premium_math(data: VaultFlatPayload, token_payload: dict = Depends(verify_premium_token)):
    """
    Executes deep multi-asset volatility projections entirely within isolated server RAM.
    Unblends commodities from fixed properties, patches early termination bugs, and binds slider yields.
    """
    is_panic = data.panic_toggle
    active_inflow = 0.0 if is_panic else (data.inc_salary + data.inc_business + data.inc_consulting)
    total_inflow = active_inflow + data.inc_rental

    raw_monthly_burn = (data.exp_rent_emi + data.exp_other_emi + data.exp_food_kirana + 
                        data.exp_utilities + data.exp_domestic_help + data.exp_fuel_commute + 
                        data.exp_dining_out + data.exp_other_1 + data.exp_other_2 + 
                        data.exp_misc_buffer)

    raw_annual_spikes = (data.ann_insurance + data.ann_school_fees + data.ann_festivals + 
                         data.ann_maintenance + data.ann_vacations)

    # Core Asset Allocation Structuring
    equity_base = data.ast_demat + data.ast_mf_eq + data.ast_pe
    debt_base = data.ast_fd + data.ast_mf_debt + data.ast_bonds + data.ast_nps
    cash_base = data.ast_cash
    metals_base = data.ast_gold_digi + data.ast_gold_phys
    real_estate_base = data.ast_re_primary + data.ast_re_second

    home_loan_base = data.lia_home_primary + data.lia_home_second
    other_loan_base = data.lia_auto + data.lia_personal + data.lia_education + data.lia_cc + data.lia_other
    total_debts = home_loan_base + other_loan_base

    absolute_expense_shock = raw_monthly_burn * (data.expense_shock / 100)
    base_monthly_outflow = raw_monthly_burn + absolute_expense_shock + (raw_annual_spikes / 12)

    final_equity = equity_base * (1 + (data.equity_shift / 100))
    final_metals = metals_base * (1 + (data.metals_shift / 100))

    # Calculate day-zero liquidation friction penalties
    if is_panic:
        total_eq_loss = data.stcg_equity * 0.20
        other_loss = debt_base * 0.01
        if data.re_liquidation > 0 and real_estate_base > 0:
            re_loss = (data.re_liquidation * (data.re_distress_pct / 100)) + (data.re_taxable_gain * (data.re_liquidation / real_estate_base) * 0.125)
        else:
            re_loss = 0.0
    else:
        total_eq_loss = max(0.0, final_equity - (equity_base * 0.7)) * 0.125
        re_loss = max(0.0, data.re_liquidation - (data.re_liquidation * 0.6)) * 0.125 if data.re_liquidation > 0 else 0.0
        other_loss = debt_base * 0.05

    total_friction = total_eq_loss + re_loss + other_loss
    effective_re_released = max(0.0, data.re_liquidation - re_loss - home_loan_base)

    # Initialize simulation timelines (Unblending commodities completely)
    sim_eq = final_equity - total_eq_loss
    sim_db = (debt_base - other_loss) + cash_base + effective_re_released
    sim_hd_re = real_estate_base - data.re_liquidation
    sim_hd_met = final_metals

    completed_months = 0
    timeline_burn_rate = base_monthly_outflow
    
    active_simulated_rent = int(round((real_estate_base * 0.03) / 12)) if data.re_liquidation > 0 else 0
    loop_simulated_rent = data.simulated_monthly_rent if data.simulated_monthly_rent > 0 else active_simulated_rent
    current_rental_yield = data.inc_rental

    # Assign dynamic cockpit returns and tax drags
    eq_growth_fraction = data.expected_equity_yield / 100
    fi_growth_fraction = data.expected_fixed_yield / 100
    met_growth_fraction = data.expected_commodity_yield / 100
    tax_drag_fraction = data.portfolio_tax_drag / 100

    # Month-by-month capital simulation matrix (Max 50 years)
    for m in range(1, 601):
        sim_age = data.current_age + (m / 12)
        
        # Compound individual asset classes independently
        sim_eq *= (1 + (eq_growth_fraction / 12) - (tax_drag_fraction / 12))
        sim_db *= (1 + (fi_growth_fraction / 12) - (tax_drag_fraction / 12))
        sim_hd_re *= (1 + (0.05 / 12)) 
        sim_hd_met *= (1 + (met_growth_fraction / 12) - (tax_drag_fraction / 12))

        # Enforce mathematical boundaries (Stop sub-zero compounding errors)
        sim_eq = max(0.0, sim_eq)
        sim_db = max(0.0, sim_db)
        sim_hd_re = max(0.0, sim_hd_re)
        sim_hd_met = max(0.0, sim_hd_met)

        active_career_inflow = 0.0 if sim_age >= 60 else active_inflow
        if m % 12 == 0:
             current_rental_yield *= 0.98
        real_time_inflow = active_career_inflow + (0.0 if is_panic else current_rental_yield)

        running_monthly_burn = (timeline_burn_rate - (data.exp_rent_emi + data.exp_other_emi)) + loop_simulated_rent
        monthly_deficit = running_monthly_burn - real_time_inflow

        if monthly_deficit > 0:
            if sim_db >= monthly_deficit:
                 sim_db -= monthly_deficit
            else:
                short = monthly_deficit - sim_db
                sim_db = 0
            
            if sim_eq >= short:
                    sim_eq -= short
            else:
                short = short - sim_eq
                sim_eq = 0
         
            if sim_hd_met >= short:
                sim_hd_met -= short
            else:
                short = short - sim_hd_met
                sim_hd_met = 0
                if sim_hd_re >= short:
                    sim_hd_re -= short
                else:
                    sim_hd_re = 0
                    break # Core bankruptcy reached
        else:
            sim_db += abs(monthly_deficit)

        completed_months += 1
        if m % 12 == 0:
            timeline_burn_rate *= (1 + (data.inflation_slider / 100))
            loop_simulated_rent *= (1 + (data.inflation_slider / 100))

    surviving_pool = sim_eq + sim_db + sim_hd_re + sim_hd_met

    return {
        "completed_months": completed_months,
        "total_friction": total_friction,
        "total_eq_loss": total_eq_loss,
        "re_loss": re_loss,
        "other_loss": other_loss,
        "effective_re_released": effective_re_released,
        "final_equity": final_equity,
        "final_metals": final_metals,
        "equity_base": equity_base,
        "debt_base": debt_base,
        "cash_base": cash_base,
        "metals_base": metals_base,
        "real_estate_base": real_estate_base,
        "home_loan_base": home_loan_base,
        "total_debts": total_debts,
        "raw_monthly_burn": raw_monthly_burn,
        "raw_annual_spikes": raw_annual_spikes,
        "surviving_pool": surviving_pool
    }
