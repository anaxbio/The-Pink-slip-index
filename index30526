    <script>
        const fmt = (num) => new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 }).format(num || 0);

        function formatIndianWords(number) {
            if (!number || number === 0) return "Zero Rupees";
            const crores = Math.floor(number / 10000000); let remainder = number % 10000000;
            const lakhs = Math.floor(remainder / 100000); remainder = remainder % 100000;
            const thousands = Math.floor(remainder / 1000); const rupees = remainder % 1000;
            let result = [];
            if (crores > 0) result.push(`${crores} Crore${crores > 1 ? 's' : ''}`);
            if (lakhs > 0) result.push(`${lakhs} Lakh${lakhs > 1 ? 's' : ''}`);
            if (thousands > 0) result.push(`${thousands} Thousand`);
            if (rupees > 0 || result.length === 0) result.push(`${rupees} Rupee${rupees > 1 || rupees === 0 ? 's' : ''}`);
            return result.join(" ");
        }

        const bindDrawer = (btnId, drawerId) => {
            document.getElementById(btnId).addEventListener('click', (e) => {
                document.querySelectorAll('.drawer').forEach(d => d.classList.remove('active'));
                document.querySelectorAll('.drawer-btn').forEach(b => b.classList.remove('active'));
                document.getElementById(drawerId).classList.add('active');
                e.target.classList.add('active');
            });
        };
        bindDrawer('nav-costs', 'drawer-costs'); bindDrawer('nav-income', 'drawer-income'); bindDrawer('nav-money', 'drawer-money'); bindDrawer('nav-loans', 'drawer-loans');

        document.getElementById('btn-reset-sliders').addEventListener('click', () => {
            document.getElementById('equity_shift').value = 0; 
            document.getElementById('metals_shift').value = 0; 
            document.getElementById('expense_shock').value = 0; 
            calculate();
        });

        function openPremiumModal() { document.getElementById('premium_modal').style.display = 'flex'; }
        function closePremiumModal() { document.getElementById('premium_modal').style.display = 'none'; }

        document.querySelectorAll('.accordion-toggle').forEach(toggle => {
            toggle.addEventListener('click', function() {
                const content = this.nextElementSibling; const isOpen = content.classList.contains('active');
                this.closest('.drawer').querySelectorAll('.group-content').forEach(c => c.classList.remove('active'));
                this.closest('.drawer').querySelectorAll('.accordion-toggle span').forEach(s => s.innerText = '▼');
                if (!isOpen) { content.classList.add('active'); this.querySelector('span').innerText = '▲'; }
            });
        });

        // --- DUMMY MATH ENGINE (Free Variables Only) ---
        function calculate() {
            if(document.getElementById('app-container').style.display === 'none') return;

            const current_age = Number(document.getElementById('current_age').value);
            const inflation_pct = 6; // Locked at 6% for free tier

            // 1. Silent Summation of Granular UI Inputs
            const raw_monthly_burn = Number(document.getElementById('exp_rent_emi').value) + Number(document.getElementById('exp_other_emi').value) + Number(document.getElementById('exp_food_kirana').value) + Number(document.getElementById('exp_utilities').value) + Number(document.getElementById('exp_domestic_help').value) + Number(document.getElementById('exp_fuel_commute').value) + Number(document.getElementById('exp_dining_out').value) + Number(document.getElementById('exp_other_1').value) + Number(document.getElementById('exp_other_2').value) + Number(document.getElementById('exp_misc_buffer').value);
            const raw_annual_spikes = Number(document.getElementById('ann_insurance').value) + Number(document.getElementById('ann_school_fees').value) + Number(document.getElementById('ann_festivals').value) + Number(document.getElementById('ann_maintenance').value) + Number(document.getElementById('ann_vacations').value);
            
            document.getElementById('lbl_total_monthly_burn').innerText = fmt(raw_monthly_burn);
            document.getElementById('lbl_total_annual_spikes').innerText = fmt(raw_annual_spikes);

            const equity_base = Number(document.getElementById('ast_demat').value) + Number(document.getElementById('ast_mf_eq').value); 
            const debt_base = Number(document.getElementById('ast_fd').value) + Number(document.getElementById('ast_mf_debt').value) + Number(document.getElementById('ast_nps').value); 
            const cash_base = Number(document.getElementById('ast_cash').value);
            const metals_base = Number(document.getElementById('ast_gold_digi').value) + Number(document.getElementById('ast_gold_phys').value);
            const real_estate_base = Number(document.getElementById('ast_re_primary').value); 
            
            document.getElementById('lbl_total_assets').innerText = fmt(equity_base + debt_base + cash_base + metals_base + real_estate_base);

            const home_loan_base = Number(document.getElementById('lia_home_primary').value) + Number(document.getElementById('lia_home_second').value);
            const other_loan_base = Number(document.getElementById('lia_auto').value) + Number(document.getElementById('lia_personal').value) + Number(document.getElementById('lia_education').value) + Number(document.getElementById('lia_cc').value) + Number(document.getElementById('lia_other').value);
            document.getElementById('lbl_total_liabilities').innerText = fmt(home_loan_base + other_loan_base);

            // 2. Crisis & Slider Shifts
            const equity_shift = Number(document.getElementById('equity_shift').value);
            const metals_shift = Number(document.getElementById('metals_shift').value);
            const expense_shock_pct = Number(document.getElementById('expense_shock').value);

            document.getElementById('txt_equity').innerHTML = equity_shift === 0 ? '<span style="color:var(--text-muted)">🟢 Baseline Markets</span>' : equity_shift < -30 ? '<span style="color:var(--accent-danger)">🚨 Systemic Crash</span>' : '<span style="color:#f59e0b">⚠️ Market Tailspin</span>';
            document.getElementById('txt_metals').innerHTML = metals_shift === 0 ? '<span style="color:var(--text-muted)">🟢 Stable Gold</span>' : metals_shift > 30 ? '<span style="color:var(--accent-safe)">🚀 Safe Haven Rally</span>' : '<span style="color:#f59e0b">⚠️ Correction Drift</span>';
            document.getElementById('txt_expense').innerHTML = expense_shock_pct > 0 ? `<span style="color:#f97316">💸 +${expense_shock_pct}% Shock Spikes</span>` : '<span style="color:var(--text-muted)">🟢 Base Burn</span>';
            
            // 3. Cash Flow Math
            const total_inflow = Number(document.getElementById('inc_salary').value) + Number(document.getElementById('inc_business').value) + Number(document.getElementById('inc_consulting').value) + Number(document.getElementById('inc_rental').value);
            const base_monthly_outflow = raw_monthly_burn + (raw_monthly_burn * (expense_shock_pct / 100)) + (raw_annual_spikes / 12);
            const net_monthly_cashflow = total_inflow - (base_monthly_outflow * (1 + (inflation_pct / 100)));

            const cashflowBox = document.getElementById('cashflow_box');
            const cashflowLabel = document.getElementById('cashflow_label');
            const cashflowVal = document.getElementById('lbl_net_cashflow');
            if (net_monthly_cashflow >= 0) {
                cashflowBox.style.background = '#F0FDF4'; cashflowBox.style.borderColor = '#BBF7D0'; cashflowBox.style.color = '#166534';
                cashflowLabel.innerText = "CASH FLOW SURPLUS"; cashflowVal.innerText = "+₹" + fmt(net_monthly_cashflow);
            } else {
                cashflowBox.style.background = '#FEF2F2'; cashflowBox.style.borderColor = '#FECACA'; cashflowBox.style.color = '#991B1B';
                cashflowLabel.innerText = "CASH FLOW DEFICIT"; cashflowVal.innerText = "-₹" + fmt(Math.abs(net_monthly_cashflow));
            }

            // 4. Basic Linear 600-Month Simulation Loop (No tax friction logic)
            const final_equity = equity_base * (1 + (equity_shift / 100));
            const final_metals = metals_base * (1 + (metals_shift / 100));
            let liquid_pool = final_equity + debt_base + cash_base + final_metals;
            liquid_pool = Math.max(0, liquid_pool - other_loan_base);
            
            let completed_months = 0;
            let timeline_burn = base_monthly_outflow;

            for (let m = 1; m <= 600; m++) {
                let real_inflow = (current_age + (m/12)) >= 60 ? 0 : total_inflow; 
                let monthly_deficit = timeline_burn - real_inflow;
                
                if (monthly_deficit > 0) {
                    liquid_pool -= monthly_deficit;
                    if (liquid_pool <= 0) break;
                } else {
                    liquid_pool += Math.abs(monthly_deficit);
                }
                
                liquid_pool *= (1 + (0.07 / 12));
                completed_months++;
                if (m % 12 === 0) timeline_burn *= (1 + (inflation_pct / 100));
            }

            // 5. UI Output Updates
            document.getElementById('val_months').innerText = fmt(completed_months); 
            document.getElementById('val_years').innerText = `(${Math.round((completed_months/12) * 10) / 10} Yrs)`; 
            document.getElementById('val_total').innerText = completed_months >= 600 ? "Networth level strong" : `Your Networth Shields You Until Age ${Math.round(current_age + (completed_months / 12))}`;

            const banner = document.getElementById('banner');
            if (completed_months < 6) {
                banner.style.backgroundColor = "#FFF5F5"; banner.style.borderColor = "var(--accent-danger)";
                document.getElementById('status_text').innerText = "🚨 LIQUIDITY LIQUIDATION OVERRUN TRIGGERED";
                document.getElementById('hero_text').innerText = `Simulation Breach Point Discovered at Month ${Math.round(completed_months)}`;
            } else {
                banner.style.backgroundColor = "#ECFDF5"; banner.style.borderColor = "var(--accent-safe)";
                document.getElementById('status_text').innerText = "🟢 RUNWAY CAPACITY SECURE";
                document.getElementById('hero_text').innerText = `Your Networth Shields You Until Age ${Math.round(current_age + (completed_months / 12))}`;
            }

            const vault_table = document.getElementById('vault_table');
            document.getElementById('table_header').innerText = "🔄 Networth Vault Impact Matrix";
            document.getElementById('table_head').innerHTML = `<tr><th>Asset Segment Class</th><th>Your Baseline Value</th><th>Crisis Test Impact Delta</th><th>Survival Portfolio Balance</th></tr>`;
            vault_table.innerHTML = `
                <tr><td>Equity Compact Asset Base</td><td>${fmt(equity_base)}</td><td><span style="color: ${final_equity - equity_base >= 0 ? 'var(--accent-safe)' : 'var(--accent-danger)'}">${fmt(final_equity - equity_base)}</span></td><td>${fmt(final_equity)}</td></tr>
                <tr><td>Fixed Income Debt Base</td><td>${fmt(debt_base)}</td><td><span>0</span></td><td>${fmt(debt_base)}</td></tr>
                <tr><td>Precious Metals Holdings</td><td>${fmt(metals_base)}</td><td><span style="color:var(--accent-safe)">+${fmt(final_metals - metals_base)}</span></td><td>${fmt(final_metals)}</td></tr>
                <tr><td>Real Estate Portfolio Base</td><td>${fmt(real_estate_base)}</td><td><span style="color:var(--text-muted)">0 (Locked)</span></td><td>${fmt(real_estate_base)}</td></tr>
            `;
        }

        // Attach listeners to active inputs only
        const activeInputsArr = [
            'inc_salary', 'inc_business', 'inc_consulting', 'inc_rental', 'current_age',
            'ast_demat', 'ast_mf_eq', 'ast_fd', 'ast_mf_debt', 'ast_nps', 'ast_cash', 'ast_gold_digi', 'ast_re_primary', 'ast_gold_phys',
            'lia_home_primary', 'lia_home_second', 'lia_auto', 'lia_personal', 'lia_education', 'lia_cc', 'lia_other', 
            'equity_shift', 'metals_shift', 'expense_shock',
            'exp_rent_emi', 'exp_other_emi', 'exp_food_kirana', 'exp_utilities', 'exp_domestic_help', 'exp_fuel_commute', 'exp_dining_out', 'exp_other_1', 'exp_other_2', 'exp_misc_buffer',
            'ann_insurance', 'ann_school_fees', 'ann_festivals', 'ann_maintenance', 'ann_vacations'
        ];
        
        activeInputsArr.forEach(id => {
            const el = document.getElementById(id);
            if (el) {
                el.addEventListener('input', () => {
                    let suffix = id.startsWith('exp_') || id.startsWith('inc_') ? " / mo" : id.startsWith('ann_') ? " / yr" : "";
                    const wordDiv = document.getElementById('words_' + id);
                    if (wordDiv) wordDiv.innerHTML = formatIndianWords(Number(el.value)) + suffix;
                    calculate();
                });
            }
        });

        calculate();
    </script>
